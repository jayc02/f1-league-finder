DATABASE_URL="postgresql://postgres:postgres@localhost:5432/racehub?schema=public"
NODE_ENV="development"
PUBLIC_SITE_URL="https://racehub.gg"

# Production/Vercel uploads should use Supabase Storage, not the local filesystem.
UPLOAD_STORAGE_PROVIDER="supabase"
# Public Supabase project URL; safe for server configuration, but do not expose service keys to the client.
SUPABASE_URL="https://your-project-ref.supabase.co"
# Server-only service role key. Never prefix this with PUBLIC_ and never expose it in client-side code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Existing public bucket for profile avatars and community logos/banners. The bucket name is uploads.
# Configure the bucket as public with allowed MIME types: image/png, image/jpeg, image/webp.
SUPABASE_STORAGE_BUCKET="uploads"

# Local development fallback only. Set UPLOAD_STORAGE_PROVIDER="local" to write into this directory.
UPLOAD_STORAGE_DIR="public/uploads"

RESEND_API_KEY=""
EMAIL_FROM="RaceHub Moderation <moderation@racehub.gg>"
