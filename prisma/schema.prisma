generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PLAYER
  ORGANISER
  ADMIN
}

enum Region {
  EU
  NA
  SA
  APAC
  MENA
  GLOBAL
}

enum PreferredPlatform {
  PC
  PLAYSTATION
  XBOX
}

enum RaceSlotStatus {
  DRAFT
  OPEN
  FULL
  LOCKED
  COMPLETED
  CANCELLED
}

enum EventVisibility {
  PUBLIC
  COMMUNITY_ONLY
  UNLISTED
  PRIVATE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum HonourEventType {
  CLEAN_RACE
  COMPLAINT_FLAG
  ORGANISER_PENALTY
  ADMIN_ADJUSTMENT
  WARNING
}

enum OrganiserProfileMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum OrganiserProfileMemberStatus {
  ACTIVE
  INVITED
  BANNED
}

enum ModerationActionType {
  WARNING
  HONOUR_ADJUSTMENT
  SUSPENSION_NOTE
  RESULT_AMENDMENT
  DISPUTE_RESOLUTION
}

enum DuelStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  AWAITING_CONFIRMATION
  COMPLETED
  DISPUTED
  CANCELLED
  EXPIRED
}

enum DuelVisibility {
  PUBLIC
  COMMUNITY_ONLY
  PRIVATE
}

enum DuelCoinSide {
  HEADS
  TAILS
}

enum DuelEntryMode {
  OPEN
  BIDDED
  PRIVATE
}

enum DuelTokenPotStatus {
  NONE
  HOLDING
  AWARDED
  REFUNDED
  DISPUTED
}

enum RaceTokenLedgerType {
  DEMO_GRANT
  ADMIN_GRANT
  ADMIN_DEBIT
  BID_HOLD
  BID_RELEASE
  BID_TO_POT
  POT_AWARD
  POT_REFUND
  DUEL_CANCEL_REFUND
}

enum DuelBidStatus {
  ACTIVE
  OUTBID
  WON_SEAT
  RELEASED
  MOVED_TO_POT
  REFUNDED
  CANCELLED
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  email             String             @unique
  passwordHash      String
  eaIdTag           String?
  discordTag        String?
  psnTag            String?
  xboxTag           String?
  preferredPlatform PreferredPlatform?
  region            Region             @default(GLOBAL)
  bio               String?
  avatarUrl         String?
  role              Role               @default(PLAYER)
  honourScore       Int                @default(100)
  skillRating       Int                @default(1200)
  suspensionNote    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  sessions                    Session[]
  organiserProfile            OrganiserProfile?
  organiserProfileMemberships OrganiserProfileMember[]
  leaguesOwned                League[]                 @relation("LeagueOwner")
  raceSlotsOrganised          RaceSlot[]               @relation("SlotOrganiser")
  raceRegistrations           RaceRegistration[]
  disputesOpened              Dispute[]                @relation("DisputeOpenedBy")
  honourEvents                HonourEvent[]            @relation("HonourSubject")
  honourEventsApplied         HonourEvent[]            @relation("HonourAppliedBy")
  moderationActions           ModerationAction[]       @relation("ModerationTarget")
  adminActionsTaken           ModerationAction[]       @relation("ModerationAdmin")
  resolvedDisputes            Dispute[]                @relation("DisputeResolvedBy")
  disputeStatusLogs           DisputeStatusLog[]
  disputeEmailsSent           DisputeEmailLog[]        @relation("DisputeEmailSender")
  disputeEmailsReceived       DisputeEmailLog[]        @relation("DisputeEmailRecipient")
  resultEntries               RaceResultEntry[]
  submittedResults            RaceResult[]
  duelsCreated                Duel[]                   @relation("DuelCreator")
  duelsAccepted               Duel[]                   @relation("DuelOpponent")
  duelsWon                    Duel[]                   @relation("DuelWinner")
  duelConfirmations           DuelConfirmation[]
  raceTokenBalance            RaceTokenBalance?
  raceTokenLedger             RaceTokenLedger[]
  duelBids                    DuelBid[]
  authProviders              AuthProvider[]
  passwordResetTokens         PasswordResetToken[]

  @@index([role])
  @@index([createdAt])
  @@index([skillRating])
  @@index([honourScore])
  @@index([region])
  @@index([skillRating, honourScore])
  @@index([region, skillRating, honourScore])
}

model AuthProvider {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  email          String?
  username       String?
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OrganiserProfile {
  id                      String             @id @default(cuid())
  userId                  String             @unique
  slug                    String             @unique
  displayName             String
  shortDescription        String?
  description             String?
  brandingColor           String?
  logoUrl                 String?
  bannerUrl               String?
  websiteUrl              String?
  discordUrl              String?
  redditUrl               String?
  socials                 Json?
  gameFocus               String?
  platformFocus           PreferredPlatform?
  region                  Region             @default(GLOBAL)
  tags                    String[]           @default([])
  isPublic                Boolean            @default(true)
  featured                Boolean            @default(false)
  verified                Boolean            @default(false)
  displayedMemberCount    Int                @default(0)
  memberCountSource       String             @default("manual")
  memberCountLastSyncedAt DateTime?
  credibilityNotes        String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leagues   League[]
  raceSlots RaceSlot[]
  duels     Duel[]
  members   OrganiserProfileMember[]

  @@index([isPublic, featured])
  @@index([isPublic, featured, updatedAt])
  @@index([region])
  @@index([updatedAt])
}

model OrganiserProfileMember {
  id                 String                       @id @default(cuid())
  organiserProfileId String
  userId             String
  role               OrganiserProfileMemberRole   @default(MEMBER)
  status             OrganiserProfileMemberStatus @default(ACTIVE)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  organiserProfile OrganiserProfile @relation(fields: [organiserProfileId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organiserProfileId, userId])
  @@index([userId])
  @@index([organiserProfileId])
  @@index([status])
  @@index([role])
  @@index([organiserProfileId, status])
  @@index([organiserProfileId, role])
}

model League {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  description        String
  brandingPrimary    String?
  brandingSecondary  String?
  region             Region   @default(GLOBAL)
  active             Boolean  @default(true)
  ownerId            String
  organiserProfileId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner            User              @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  organiserProfile OrganiserProfile? @relation(fields: [organiserProfileId], references: [id], onDelete: SetNull)
  raceSlots        RaceSlot[]

  @@index([slug])
}

model RaceSlot {
  id                   String             @id @default(cuid())
  title                String
  track                String?
  eventNotes           String?
  visibility           EventVisibility    @default(PUBLIC)
  leagueId             String
  organiserId          String
  organiserProfileId   String?
  scheduledAt          DateTime
  region               Region             @default(GLOBAL)
  game                 String             @default("F1")
  platform             PreferredPlatform?
  crossplay            Boolean            @default(false)
  formatDetails        String
  lobbySettings        Json?
  maxPlayers           Int
  status               RaceSlotStatus     @default(DRAFT)
  registrationCutoffAt DateTime
  rulesSummary         String
  stakeTierMetadata    String?
  cancellationReason   String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  league            League             @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  organiser         User               @relation("SlotOrganiser", fields: [organiserId], references: [id], onDelete: Restrict)
  organiserProfile  OrganiserProfile?  @relation(fields: [organiserProfileId], references: [id], onDelete: SetNull)
  registrations     RaceRegistration[]
  result            RaceResult?
  disputes          Dispute[]
  honourEvents      HonourEvent[]
  moderationActions ModerationAction[]

  @@index([leagueId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([visibility, status, scheduledAt])
  @@index([visibility, scheduledAt])
  @@index([organiserProfileId, scheduledAt])
  @@index([organiserId, scheduledAt])
  @@index([organiserProfileId, visibility, status, scheduledAt])
  @@index([scheduledAt])
  @@index([status])
}

model Duel {
  id           String         @id @default(cuid())
  createdById  String
  opponentId   String?
  winnerUserId String?
  communityId  String?
  status       DuelStatus     @default(OPEN)
  visibility   DuelVisibility @default(PUBLIC)
  ranked       Boolean        @default(true)
  entryMode    DuelEntryMode  @default(OPEN)

  game            String
  track           String
  carClass        String?
  platform        PreferredPlatform?
  crossplay       Boolean            @default(true)
  assists         String             @default("ASSISTS_ALLOWED")
  damageLevel     String             @default("STANDARD")
  raceLength      String             @default("25%")
  weather         String             @default("Dynamic")
  rulesSummary    String?
  scheduledAt     DateTime?
  expiresAt       DateTime?
  resultAppliedAt DateTime?
  bidClosesAt      DateTime?
  biddingLockedAt  DateTime?
  startingBidTokens Int?
  maxBidTokens      Int?
  winningBidId      String?
  tokenPot          Int                @default(0)
  tokenPotAwardedAt DateTime?
  tokenPotWinnerUserId String?
  tokenPotStatus    DuelTokenPotStatus @default(NONE)

  playerAChoice        DuelCoinSide @default(HEADS)
  playerBChoice        DuelCoinSide @default(TAILS)
  coinFlipValue        Int?
  coinFlipWinnerUserId String?
  leg1AdvantageUserId  String?
  leg2AdvantageUserId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy     User               @relation("DuelCreator", fields: [createdById], references: [id], onDelete: Cascade)
  opponent      User?              @relation("DuelOpponent", fields: [opponentId], references: [id], onDelete: SetNull)
  winner        User?              @relation("DuelWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  community     OrganiserProfile?  @relation(fields: [communityId], references: [id], onDelete: SetNull)
  legs          DuelLeg[]
  confirmations DuelConfirmation[]
  bids          DuelBid[]

  @@index([status, visibility, scheduledAt])
  @@index([visibility, status, createdAt])
  @@index([createdById, status])
  @@index([opponentId, status])
  @@index([winnerUserId])
  @@index([resultAppliedAt])
  @@index([communityId, status])
  @@index([status, ranked])
}

model RaceTokenBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  available      Int      @default(0)
  held           Int      @default(0)
  lifetimeEarned Int      @default(0)
  lifetimeSpent  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RaceTokenLedger {
  id            String              @id @default(cuid())
  userId        String
  amount        Int
  type          RaceTokenLedgerType
  reason        String
  duelId        String?
  bidId         String?
  relatedUserId String?
  metadata      Json?
  createdAt     DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([duelId])
  @@index([bidId])
  @@index([type])
}

model DuelBid {
  id           String       @id @default(cuid())
  duelId       String
  userId       String
  amountTokens Int
  status       DuelBidStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  duel Duel @relation(fields: [duelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([duelId, createdAt])
  @@index([userId, createdAt])
  @@index([duelId, amountTokens])
  @@index([status])
}

model DuelLeg {
  id              String    @id @default(cuid())
  duelId          String
  legNumber       Int
  advantageUserId String?
  winnerUserId    String?
  playerAScore    Int?
  playerBScore    Int?
  playerATimeMs   Int?
  playerBTimeMs   Int?
  notes           String?
  evidenceUrl     String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  duel Duel @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, legNumber])
  @@index([winnerUserId])
  @@index([advantageUserId])
}

model DuelConfirmation {
  id                 String   @id @default(cuid())
  duelId             String
  userId             String
  confirmedWinnerId  String?
  leg1WinnerId       String?
  leg2WinnerId       String?
  playerATotalTimeMs Int?
  playerBTotalTimeMs Int?
  evidenceUrl        String?
  confirmedAt        DateTime @default(now())
  notes              String?

  duel Duel @relation(fields: [duelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
  @@index([userId])
  @@index([confirmedWinnerId])
}

model RaceRegistration {
  id         String   @id @default(cuid())
  raceSlotId String
  userId     String
  createdAt  DateTime @default(now())

  raceSlot RaceSlot @relation(fields: [raceSlotId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([raceSlotId, userId])
  @@index([userId, createdAt])
  @@index([userId, raceSlotId])
  @@index([userId])
  @@index([raceSlotId])
}

model RaceResult {
  id                String    @id @default(cuid())
  raceSlotId        String    @unique
  submittedById     String
  notes             String?
  evidenceUrl       String?
  confirmationState String    @default("submitted")
  submittedAt       DateTime  @default(now())
  confirmedAt       DateTime?
  amendedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  raceSlot     RaceSlot          @relation(fields: [raceSlotId], references: [id], onDelete: Cascade)
  submittedBy  User              @relation(fields: [submittedById], references: [id], onDelete: Restrict)
  entries      RaceResultEntry[]
  disputes     Dispute[]
  honourEvents HonourEvent[]

  @@index([submittedAt])
  @@index([submittedById])
}

model RaceResultEntry {
  id                String   @id @default(cuid())
  raceResultId      String
  userId            String
  finishingPosition Int
  pointsAwarded     Int
  ratingDelta       Int      @default(0)
  honourDelta       Int      @default(0)
  createdAt         DateTime @default(now())

  raceResult RaceResult @relation(fields: [raceResultId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([raceResultId, userId])
  @@index([userId])
  @@index([raceResultId])
  @@index([pointsAwarded])
  @@index([finishingPosition])
  @@index([userId, finishingPosition])
  @@index([userId, pointsAwarded])
  @@index([userId, raceResultId])
}

model Dispute {
  id              String        @id @default(cuid())
  raceSlotId      String
  raceResultId    String?
  openedById      String
  reason          String
  details         String?
  status          DisputeStatus @default(OPEN)
  adminNotes      String?
  resolutionNotes String?
  resolvedAt      DateTime?
  resolvedById    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  raceSlot   RaceSlot    @relation(fields: [raceSlotId], references: [id], onDelete: Cascade)
  raceResult RaceResult? @relation(fields: [raceResultId], references: [id], onDelete: SetNull)
  openedBy   User        @relation("DisputeOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  resolvedBy User?       @relation("DisputeResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  moderationActions ModerationAction[]
  statusLogs        DisputeStatusLog[]
  emailLogs         DisputeEmailLog[]

  @@index([status, createdAt])
  @@index([openedById, createdAt])
  @@index([resolvedById, resolvedAt])
}

model DisputeStatusLog {
  id          String         @id @default(cuid())
  disputeId   String
  fromStatus  DisputeStatus?
  toStatus    DisputeStatus
  note        String?
  changedById String
  createdAt   DateTime       @default(now())

  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id], onDelete: Restrict)

  @@index([disputeId, createdAt])
}

model DisputeEmailLog {
  id             String   @id @default(cuid())
  disputeId      String
  sentById       String
  recipientId    String
  recipientEmail String
  subject        String
  bodyPreview    String
  createdAt      DateTime @default(now())

  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sentBy    User    @relation("DisputeEmailSender", fields: [sentById], references: [id], onDelete: Restrict)
  recipient User    @relation("DisputeEmailRecipient", fields: [recipientId], references: [id], onDelete: Restrict)

  @@index([disputeId, createdAt])
  @@index([recipientId, createdAt])
}

model HonourEvent {
  id            String          @id @default(cuid())
  userId        String
  raceSlotId    String?
  raceResultId  String?
  type          HonourEventType
  delta         Int
  reason        String
  warningIssued Boolean         @default(false)
  metadata      Json?
  appliedById   String?
  createdAt     DateTime        @default(now())

  user       User        @relation("HonourSubject", fields: [userId], references: [id], onDelete: Cascade)
  raceSlot   RaceSlot?   @relation(fields: [raceSlotId], references: [id], onDelete: SetNull)
  raceResult RaceResult? @relation(fields: [raceResultId], references: [id], onDelete: SetNull)
  appliedBy  User?       @relation("HonourAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([userId, type, delta])
}

model ModerationAction {
  id           String               @id @default(cuid())
  actionType   ModerationActionType
  targetUserId String
  adminId      String
  disputeId    String?
  raceSlotId   String?
  notes        String
  metadata     Json?
  createdAt    DateTime             @default(now())

  targetUser User      @relation("ModerationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  admin      User      @relation("ModerationAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  dispute    Dispute?  @relation(fields: [disputeId], references: [id], onDelete: SetNull)
  raceSlot   RaceSlot? @relation(fields: [raceSlotId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt])
  @@index([adminId, createdAt])
}
