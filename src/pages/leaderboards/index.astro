---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { fetchFromApi } from '@/lib/server-api';

export const prerender = false;

const views = [
  { key: 'overall', label: 'Overall', metric: 'SR', description: 'Best all-around pace and consistency.' },
  { key: 'honour', label: 'Honour', metric: 'Honour', description: 'Sportsmanship and clean conduct leaders.' },
  { key: 'clean', label: 'Clean Drivers', metric: 'Clean Finishes', description: 'Drivers delivering racecraft without contact penalties.' },
  { key: 'wins', label: 'Wins', metric: 'Wins', description: 'Highest race-winning performances this season.' },
  { key: 'weekly', label: 'Weekly Form', metric: 'Momentum', description: 'Drivers trending up over the last 7 days.' },
] as const;

const selectedView = views.find((view) => view.key === Astro.url.searchParams.get('view')) ?? views[0];

const response = await fetchFromApi<{
  type: string;
  leaderboard: Array<{
    id: string;
    username: string;
    avatarUrl: string | null;
    region: string;
    honourScore: number;
    skillRating: number;
    racesEntered: number;
    wins: number;
    podiums: number;
    cleanFinishes: number;
    points: number;
    averageFinish: number | null;
    trend: 'up' | 'down' | 'stable';
  }>;
}>(Astro, `/api/leaderboards/competitive?type=${selectedView.key}&limit=50`).catch(() => ({ type: selectedView.key, leaderboard: [] }));

const topThree = response.leaderboard.slice(0, 3);
const remaining = response.leaderboard.slice(3);
const trendLabel: Record<'up' | 'down' | 'stable', string> = { up: '▲ Rising', stable: '■ Stable', down: '▼ Cooling' };

const metricLabel = (entry: (typeof response.leaderboard)[number]) => {
  if (selectedView.key === 'honour') return `${entry.honourScore} honour`;
  if (selectedView.key === 'clean') return `${entry.cleanFinishes} clean finishes`;
  if (selectedView.key === 'wins') return `${entry.wins} wins`;
  if (selectedView.key === 'weekly') return `${entry.points} total pts`;
  return `${entry.skillRating} SR`;
};
---
<BaseLayout title="Leaderboards | GRID//ONE">
  <section class="section-shell">
    <div class="panel rounded-3xl p-6 md:p-8">
      <p class="text-xs uppercase tracking-[0.26em] text-slate-400">Competitive rankings</p>
      <div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="section-title">Leaderboards</h1>
          <p class="mt-3 max-w-3xl text-sm text-slate-300">{selectedView.description} Rankings update dynamically from active race participation and confirmed results.</p>
        </div>
        <p class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.2em] text-slate-200">Metric · {selectedView.metric}</p>
      </div>
      <div class="mt-6 flex flex-wrap gap-2">
        {views.map((view) => (
          <a
            href={`/leaderboards?view=${view.key}`}
            class:list={[
              'rounded-full border px-4 py-2 text-xs uppercase tracking-[0.16em] transition',
              view.key === selectedView.key
                ? 'border-white/45 bg-white text-black'
                : 'border-white/10 bg-white/5 text-slate-300 hover:border-white/30 hover:text-white',
            ]}
          >
            {view.label}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {topThree.map((entry, index) => (
        <article class:list={[
          'panel relative overflow-hidden rounded-3xl p-5',
          index === 0 ? 'md:col-span-2 border-white/30 bg-gradient-to-br from-white/15 to-white/[0.04]' : '',
        ]}>
          <div class="absolute right-4 top-4 text-[11px] uppercase tracking-[0.2em] text-slate-400">Rank #{index + 1}</div>
          <div class="flex items-center gap-4">
            <img src={entry.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${entry.username}`} alt={`${entry.username} avatar`} class="h-14 w-14 rounded-2xl border border-white/15 bg-white/5 object-cover" />
            <div>
              <h2 class="font-display text-2xl text-white">{entry.username}</h2>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] text-slate-400">{entry.region} · {trendLabel[entry.trend]}</p>
            </div>
          </div>
          <div class="mt-5 grid grid-cols-2 gap-3 text-sm">
            <p class="rounded-xl border border-white/10 bg-black/20 px-3 py-2"><span class="block text-xs text-slate-400">Primary</span>{metricLabel(entry)}</p>
            <p class="rounded-xl border border-white/10 bg-black/20 px-3 py-2"><span class="block text-xs text-slate-400">Races Entered</span>{entry.racesEntered}</p>
            <p class="rounded-xl border border-white/10 bg-black/20 px-3 py-2"><span class="block text-xs text-slate-400">Podiums</span>{entry.podiums}</p>
            <p class="rounded-xl border border-white/10 bg-black/20 px-3 py-2"><span class="block text-xs text-slate-400">Avg Finish</span>{entry.averageFinish ? entry.averageFinish.toFixed(1) : '—'}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-6 panel rounded-3xl p-4 md:p-6">
      <div class="hidden grid-cols-[80px_minmax(220px,1.6fr)_repeat(5,minmax(90px,1fr))] items-center px-4 pb-3 text-[11px] uppercase tracking-[0.2em] text-slate-500 md:grid">
        <p>Rank</p><p>Driver</p><p>SR</p><p>Honour</p><p>Wins</p><p>Podiums</p><p>Clean</p>
      </div>
      <div class="space-y-2">
        {remaining.map((entry, index) => (
          <article class="grid gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3 transition hover:border-white/35 hover:bg-white/[0.06] md:grid-cols-[80px_minmax(220px,1.6fr)_repeat(5,minmax(90px,1fr))] md:items-center">
            <p class="text-lg font-semibold text-white">#{index + 4}</p>
            <div class="flex items-center gap-3">
              <img src={entry.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${entry.username}`} alt={`${entry.username} avatar`} class="h-10 w-10 rounded-xl border border-white/10 object-cover" />
              <div>
                <p class="text-sm font-semibold text-white">{entry.username}</p>
                <p class="text-xs uppercase tracking-[0.18em] text-slate-500">{entry.region} · {trendLabel[entry.trend]}</p>
              </div>
            </div>
            <p class="text-sm text-slate-200">{entry.skillRating}</p>
            <p class="text-sm text-slate-200">{entry.honourScore}</p>
            <p class="text-sm text-slate-200">{entry.wins}</p>
            <p class="text-sm text-slate-200">{entry.podiums}</p>
            <p class="text-sm text-slate-200">{entry.cleanFinishes}</p>
          </article>
        ))}
      </div>
      {!response.leaderboard.length && <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 text-sm text-slate-300">No leaderboard data yet. Complete race slots to populate rankings.</p>}
    </div>
  </section>
</BaseLayout>
