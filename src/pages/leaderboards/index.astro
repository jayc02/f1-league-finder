---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeaderboardListMobile from '@/components/leaderboards/LeaderboardListMobile.astro';
import LeaderboardTableDesktop from '@/components/leaderboards/LeaderboardTableDesktop.astro';
import { publicPageShort, setAstroCache } from '@/lib/server/cache-control';
import { getRankedLeaderboard, type CompetitiveLeaderboardType, type LeaderboardEntry } from '@/server/services/leaderboard.service';

export const prerender = false;
setAstroCache(Astro, publicPageShort);

const views = [
  { key: 'overall', label: 'Overall', metric: 'SR', description: 'Best all-around pace and consistency.' },
  { key: 'honour', label: 'Honour', metric: 'Honour', description: 'Sportsmanship and clean-conduct elites.' },
  { key: 'clean', label: 'Clean Drivers', metric: 'Clean Ratio', description: 'Incident-light racers with elite discipline.' },
  { key: 'wins', label: 'Wins', metric: 'Wins', description: 'Pure race-winning output.' },
  { key: 'weekly', label: 'Weekly Movers', metric: '7D Points', description: 'Who is climbing right now.' },
] as const;

const selectedView = views.find((view) => view.key === Astro.url.searchParams.get('view')) ?? views[0];
const type = selectedView.key as CompetitiveLeaderboardType;
let topHundred: LeaderboardEntry[] = [];
let leaderboardError: string | null = null;
try {
  topHundred = await getRankedLeaderboard(type, { limit: 100 });
} catch (error) {
  console.error('[leaderboards page] Failed to load leaderboard', error);
  leaderboardError = 'Leaderboards are temporarily unavailable. Please refresh in a moment.';
}
---

<BaseLayout title="Leaderboards | RaceHub" lightweightApp={true}>
  <section class="section-shell relative isolate">
    <div class="panel relative overflow-hidden rounded-3xl p-5 md:p-8">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-300 md:tracking-[0.26em]">Competitive rankings</p>
      <div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="min-w-0">
          <h1 class="section-title">Top 100 Leaderboard</h1>
          <p class="mt-3 max-w-3xl text-sm text-slate-200 line-clamp-2 md:line-clamp-none">{selectedView.description}</p>
          {leaderboardError && <p class="mt-4 rounded-2xl border border-amber-300/30 bg-amber-500/10 p-3 text-sm text-amber-100">{leaderboardError}</p>}
        </div>
        <p class="rh-badge w-fit rounded-full border border-white/15 bg-black/40 px-4 py-2 text-xs uppercase tracking-[0.16em] text-slate-100 md:tracking-[0.2em]">Metric · {selectedView.metric}</p>
      </div>
      <div class="mt-6 flex gap-2 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden md:flex-wrap md:overflow-visible">
        {views.map((view) => <a href={`/leaderboards?view=${view.key}`} class:list={['rh-badge min-h-10 rounded-full border px-4 py-2 text-xs uppercase tracking-[0.12em] transition md:tracking-[0.14em]', view.key === selectedView.key ? 'border-white/60 bg-white text-black shadow-[0_0_30px_rgba(255,255,255,.2)]' : 'border-white/10 bg-white/5 text-slate-300 hover:border-white/35 hover:text-white']}>{view.label}</a>)}
      </div>
    </div>

    <article id="your-standing" class="panel mt-6 hidden rounded-3xl border-white/15 bg-gradient-to-br from-emerald-300/10 via-black/70 to-black/70 p-3 sm:p-6"></article>

    <LeaderboardListMobile entries={topHundred} />
    <LeaderboardTableDesktop entries={topHundred} />
    {!topHundred.length && <p class="mt-6 rounded-2xl border border-white/10 bg-white/[0.03] p-6 text-sm text-slate-300">No leaderboard data yet. Complete race slots to populate rankings.</p>}
  </section>
  <script is:inline define:vars={{ type }}>
    const container = document.getElementById('your-standing');
    const hideStanding = () => { container?.classList.add('hidden'); };
    const escapeHtml = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[char]);
    const numericText = (value, fallback = 0) => { const number = Number(value); return Number.isFinite(number) ? number : fallback; };
    const honourGrade = (score) => { const n = numericText(score); if (n >= 140) return 'S'; if (n >= 115) return 'A'; if (n >= 90) return 'B'; if (n >= 60) return 'C'; return 'D'; };
    const avatarFor = (entry) => { const explicitAvatar = typeof entry.avatarUrl === 'string' ? entry.avatarUrl : null; if (explicitAvatar) return escapeHtml(explicitAvatar); return `https://api.dicebear.com/9.x/initials/svg?seed=${encodeURIComponent(String(entry.username ?? 'Driver'))}`; };
    const renderStanding = (payload) => {
      if (!container || !payload?.me || !Array.isArray(payload.window)) { hideStanding(); return; }
      const meId = String(payload.me.id ?? '');
      const rows = payload.window.map((entry) => {
        const entryId = String(entry?.id ?? '');
        const username = escapeHtml(entry?.username ?? 'Driver');
        const avatarUrl = avatarFor(entry ?? {});
        const rank = numericText(entry?.rank, '—');
        const skillRating = numericText(entry?.skillRating);
        const activeClasses = entryId === meId ? 'border-emerald-300/50 bg-emerald-400/10 shadow-[0_0_0_1px_rgba(110,231,183,0.12)]' : 'border-white/10 bg-white/[0.04]';
        return `<div class="flex items-center gap-3 rounded-2xl border px-3 py-3 ${activeClasses}"><p class="w-12 shrink-0 text-lg font-black text-white">#${rank}</p><img src="${avatarUrl}" alt="${username} avatar" class="h-10 w-10 shrink-0 rounded-xl border border-white/10 object-cover" /><div class="min-w-0 flex-1"><p class="truncate text-sm font-semibold text-white">${username}</p><p class="text-xs text-slate-400 sm:hidden">${skillRating} SR</p></div><div class="shrink-0 text-right"><p class="hidden text-sm font-semibold text-slate-100 sm:block">${skillRating} SR</p><span class="rh-badge rounded-full border border-emerald-300/40 bg-emerald-400/15 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.12em] text-emerald-100">${honourGrade(entry?.honourScore)}</span></div></div>`;
      }).join('');
      container.innerHTML = `<div class="flex items-center justify-between gap-3"><div><p class="text-xs uppercase tracking-[0.18em] text-slate-400">Your standing</p><h2 class="font-display text-2xl">Around Your Rank · #${numericText(payload.me.rank, '—')}</h2></div><a href="/profile" class="rh-badge rounded-full border border-white/15 px-3 py-2 text-[11px] uppercase tracking-[0.14em] text-slate-300 hover:text-white">Profile</a></div><div class="mt-4 space-y-2">${rows}</div>`;
      container.classList.remove('hidden');
    };
    if (container) fetch(`/api/leaderboards/me?view=${encodeURIComponent(type)}`, { credentials: 'include' }).then((response) => { if (response.status === 401 || response.status === 403 || !response.ok) return null; return response.json().catch(() => null); }).then(renderStanding).catch(hideStanding);
  </script>
</BaseLayout>
