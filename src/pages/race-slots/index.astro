---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { fetchFromApi } from '@/lib/server-api';
import type { RaceSlotSummary } from '@/lib/api/types';

export const prerender = false;

const { raceSlots } = await fetchFromApi<{ raceSlots: RaceSlotSummary[] }>(Astro, '/api/race-slots?limit=40').catch(() => ({ raceSlots: [] }));

const statusTone: Record<string, string> = {
  OPEN: 'border-emerald-300/30 bg-emerald-500/10 text-emerald-100',
  FULL: 'border-fuchsia-300/30 bg-fuchsia-500/10 text-fuchsia-100',
  LOCKED: 'border-amber-300/30 bg-amber-500/10 text-amber-100',
  COMPLETED: 'border-sky-300/30 bg-sky-500/10 text-sky-100',
  CANCELLED: 'border-rose-300/30 bg-rose-500/10 text-rose-100',
};
---
<BaseLayout title="Race slots | GRID//ONE">
  <section class="section-shell">
    <div class="panel rounded-3xl p-6 md:p-8">
      <p class="text-xs uppercase tracking-[0.22em] text-slate-400">Event calendar</p>
      <h1 class="section-title mt-3">Race Slots</h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-300">Browse upcoming grids, lock your seat, and track competitive events with the same premium race-day clarity as the leaderboards.</p>
    </div>

    <div class="mt-7 grid gap-4 lg:grid-cols-2">
      {raceSlots.length ? raceSlots.map((slot) => {
        const filled = Math.min(100, Math.round((slot._count.registrations / slot.maxPlayers) * 100));
        return (
          <a href={`/race-slots/${slot.id}`} class="panel group rounded-3xl p-5 transition hover:-translate-y-1 hover:border-white/35">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{slot.league.name}</p>
                <h2 class="mt-2 font-display text-2xl text-white">{slot.title}</h2>
              </div>
              <span class:list={['rounded-full border px-3 py-1 text-[10px] uppercase tracking-[0.18em]', statusTone[slot.status] ?? 'border-white/20 bg-white/10 text-white']}>
                {slot.status}
              </span>
            </div>

            <div class="mt-4 grid gap-2 text-sm text-slate-300 md:grid-cols-2">
              <p class="rounded-xl border border-white/10 bg-black/25 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-500">Scheduled</span>{new Date(slot.scheduledAt).toLocaleString()}</p>
              <p class="rounded-xl border border-white/10 bg-black/25 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-500">Cutoff</span>{new Date(slot.registrationCutoffAt).toLocaleString()}</p>
              <p class="rounded-xl border border-white/10 bg-black/25 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-500">Region / Platform</span>{slot.region} · {slot.crossplay ? 'Crossplay' : slot.platform ?? 'TBD'}</p>
              <p class="rounded-xl border border-white/10 bg-black/25 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-500">Organiser</span>{slot.organiserProfile?.displayName ?? slot.organiser.username}</p>
              <p class="rounded-xl border border-white/10 bg-black/25 px-3 py-2 md:col-span-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-500">Track / visibility</span>{slot.track ?? 'Track TBA'} · {slot.visibility}</p>
            </div>

            <div class="mt-4 rounded-xl border border-white/10 bg-white/[0.03] p-3">
              <div class="flex items-center justify-between text-xs uppercase tracking-[0.16em] text-slate-500">
                <p>Grid filled</p>
                <p>{slot._count.registrations}/{slot.maxPlayers}</p>
              </div>
              <div class="mt-2 h-2 rounded-full bg-white/10">
                <div class="h-full rounded-full bg-gradient-to-r from-white to-slate-400" style={`width:${filled}%`} />
              </div>
            </div>
          </a>
        );
      }) : <p class="panel rounded-2xl p-6 text-slate-300">No race slots found yet.</p>}
    </div>
  </section>
</BaseLayout>
