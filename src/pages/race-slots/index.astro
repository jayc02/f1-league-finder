---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { fetchFromApi } from '@/lib/server-api';
import type { RaceSlotSummary } from '@/lib/api/types';
import F1ScrollBuildCar from '@/components/F1ScrollBuildCar';

export const prerender = false;

const { raceSlots } = await fetchFromApi<{ raceSlots: RaceSlotSummary[] }>(Astro, '/api/race-slots?limit=40').catch(() => ({ raceSlots: [] }));

const statusTone: Record<string, string> = {
  OPEN: 'border-emerald-300/55 bg-emerald-500/18 text-emerald-100 shadow-[0_0_28px_rgba(16,185,129,0.18)]',
  FULL: 'border-fuchsia-300/45 bg-fuchsia-500/16 text-fuchsia-100 shadow-[0_0_26px_rgba(217,70,239,0.16)]',
  LOCKED: 'border-amber-300/50 bg-amber-500/16 text-amber-100 shadow-[0_0_26px_rgba(245,158,11,0.14)]',
  COMPLETED: 'border-sky-300/45 bg-sky-500/16 text-sky-100 shadow-[0_0_26px_rgba(14,165,233,0.16)]',
  CANCELLED: 'border-rose-300/45 bg-rose-500/18 text-rose-100 shadow-[0_0_26px_rgba(244,63,94,0.2)]',
};

const progressTone = (status: string) => {
  if (status === 'OPEN') return 'from-emerald-300 via-emerald-400 to-teal-200';
  if (status === 'FULL') return 'from-fuchsia-300 via-pink-300 to-rose-200';
  if (status === 'LOCKED') return 'from-amber-300 via-orange-300 to-yellow-200';
  if (status === 'COMPLETED') return 'from-sky-300 via-cyan-300 to-blue-200';
  if (status === 'CANCELLED') return 'from-rose-300 via-red-300 to-orange-200';
  return 'from-slate-200 to-slate-400';
};
---

<BaseLayout title="Race slots | RaceHub">
  <F1ScrollBuildCar client:only="react" />
  <section class="relative isolate overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-20 bg-black" aria-hidden="true"></div>
    <video class="pointer-events-none absolute inset-0 -z-10 h-full w-full object-cover opacity-45" autoplay muted loop playsinline preload="auto" aria-hidden="true">
      <source src="/videos/raceslot.mp4" type="video/mp4" />
    </video>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-black/80 via-black/70 to-black"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_20%,rgba(56,189,248,0.16),transparent_42%),radial-gradient(circle_at_80%_10%,rgba(244,63,94,0.16),transparent_38%),radial-gradient(circle_at_50%_100%,rgba(16,185,129,0.12),transparent_38%)]"></div>

    <div class="section-shell">
      <div class="rounded-3xl border border-white/20 bg-gradient-to-br from-white/[0.12] via-black/55 to-black/80 p-5 shadow-[0_34px_90px_rgba(0,0,0,0.75)] backdrop-blur-xl md:p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-rose-100/80">Event calendar</p>
        <h1 class="section-title mt-3">Race Slots</h1>
        <p class="mt-3 max-w-3xl text-sm text-slate-200">Browse upcoming grids, lock your seat, and track competitive events with premium race-day clarity and high-contrast scanning.</p>
      </div>

      <div class="mt-7 grid gap-5 lg:grid-cols-2">
        {raceSlots.length ? raceSlots.map((slot) => {
          const filled = Math.min(100, Math.round((slot._count.registrations / slot.maxPlayers) * 100));
          return (
            <a href={`/race-slots/${slot.id}`} class="group relative overflow-hidden rounded-3xl border border-white/20 bg-gradient-to-b from-white/[0.09] via-black/60 to-black/85 p-5 shadow-[0_24px_70px_rgba(0,0,0,0.58)] transition hover:-translate-y-1.5 hover:border-white/45 hover:shadow-[0_34px_80px_rgba(0,0,0,0.68)]">
              <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-transparent via-white/45 to-transparent opacity-60"></div>
              <div class="pointer-events-none absolute -right-8 -top-8 h-24 w-24 rounded-full bg-white/10 blur-2xl transition group-hover:bg-white/15"></div>

              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{slot.league.name}</p>
                  <h2 class="mt-2 font-display text-2xl text-white">{slot.title}</h2>
                </div>
                <span class:list={['rounded-full border px-3 py-1 text-[10px] uppercase tracking-[0.18em]', statusTone[slot.status] ?? 'border-white/20 bg-white/10 text-white']}>
                  {slot.status}
                </span>
              </div>

              <div class="mt-4 grid gap-2 text-sm text-slate-200 md:grid-cols-2">
                <p class="rounded-xl border border-white/15 bg-black/35 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-400">Scheduled</span>{new Date(slot.scheduledAt).toLocaleString()}</p>
                <p class="rounded-xl border border-white/15 bg-black/35 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-400">Cutoff</span>{new Date(slot.registrationCutoffAt).toLocaleString()}</p>
                <p class="rounded-xl border border-cyan-300/20 bg-cyan-500/10 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-cyan-100/70">Region / Platform</span>{slot.region} · {slot.crossplay ? 'Crossplay' : slot.platform ?? 'TBD'}</p>
                <p class="rounded-xl border border-violet-300/20 bg-violet-500/10 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-violet-100/70">Organiser</span>{slot.organiserProfile?.displayName ?? slot.organiser.username}</p>
                <p class="rounded-xl border border-white/15 bg-black/35 px-3 py-2 md:col-span-2"><span class="block text-[11px] uppercase tracking-[0.14em] text-slate-400">Track / visibility</span>{slot.track ?? 'Track TBA'} · {slot.visibility}</p>
              </div>

              <div class="mt-4 rounded-2xl border border-white/15 bg-black/40 p-3">
                <div class="flex items-center justify-between text-xs uppercase tracking-[0.16em] text-slate-300">
                  <p>Grid filled</p>
                  <p>{slot._count.registrations}/{slot.maxPlayers}</p>
                </div>
                <div class="mt-2 h-2.5 rounded-full bg-white/10">
                  <div class:list={['h-full rounded-full bg-gradient-to-r', progressTone(slot.status)]} style={`width:${filled}%`} />
                </div>
              </div>
            </a>
          );
        }) : <p class="panel rounded-2xl p-6 text-slate-200">No race slots found yet.</p>}
      </div>
    </div>
  </section>
</BaseLayout>
