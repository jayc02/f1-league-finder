---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { setAstroCache } from '@/lib/server/cache-control';
import { getPublicCommunitySummaries, type PublicCommunitySummary } from '@/server/services/community.service';

export const prerender = false;

// Public SSR route: communities index renders public organiser profiles directly from OrganiserProfile.
// Temporarily disabled public caching while verifying fresh community discovery output.
setAstroCache(Astro, 'public, max-age=0, s-maxage=60, stale-while-revalidate=300');

const safeExternalUrl = (url?: string | null) => {
  if (!url) return null;
  try {
    const parsed = new URL(url);
    return ['http:', 'https:'].includes(parsed.protocol) ? parsed.toString() : null;
  } catch {
    return null;
  }
};

let communities: PublicCommunitySummary[] = [];
let communitiesError: unknown = null;

try {
  communities = await getPublicCommunitySummaries(30);

  if (import.meta.env.DEV) {
    console.log('[communities page]', communities.map((community) => community.slug));
  }
} catch (error) {
  communitiesError = error;
  console.error('[communities page] Failed to load public communities', error);
}
---

<BaseLayout title="Communities | RaceHub">
  <section class="section-shell relative isolate">
    <div class="pointer-events-none absolute inset-x-0 -top-8 bottom-0 -z-20 overflow-hidden rounded-[2.2rem]">
      <div class="absolute inset-0 bg-cover bg-center opacity-36" style="background-image:url('/pictures/communititesback.webp')"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_16%_20%,rgba(56,189,248,.16),transparent_36%),radial-gradient(circle_at_86%_0%,rgba(244,114,182,.14),transparent_36%),linear-gradient(180deg,rgba(5,8,12,.45)_0%,rgba(3,4,6,.82)_46%,rgba(1,1,2,.97)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(2,4,6,.9)_0%,transparent_24%,transparent_78%,rgba(2,4,6,.9)_100%)]"></div>
    </div>

    <div class="panel relative overflow-hidden rounded-3xl p-5 md:p-8">
      <div class="absolute -left-20 -top-20 h-56 w-56 rounded-full bg-sky-300/20 blur-3xl"></div>
      <div class="absolute -right-16 top-0 h-52 w-52 rounded-full bg-fuchsia-400/15 blur-3xl"></div>
      <p class="text-xs uppercase tracking-[0.22em] text-slate-300">Community discovery</p>
      <h1 class="section-title mt-3">Organiser Communities</h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-200">Browse public organiser communities, active race calendars, and trusted programs where the next grid opens.</p>
    </div>

    <div class="mt-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Discover communities</p>
        <h2 class="font-display text-3xl text-white">All public communities</h2>
      </div>
      <p class="max-w-xl text-xs text-slate-400">Public organiser profiles appear here whether or not they are featured or verified.</p>
    </div>

    {communitiesError ? (
      <div class="mt-5 rounded-3xl border border-rose-400/30 bg-rose-950/30 p-5 text-sm text-rose-100 shadow-[0_0_40px_rgba(244,63,94,.12)]">
        <p class="font-display text-2xl text-white">Community discovery is temporarily unavailable.</p>
        <p class="mt-2 text-rose-100/80">RaceHub could not load public organiser profiles from the database. The issue has been logged server-side.</p>
        {import.meta.env.DEV && (
          <pre class="mt-4 overflow-x-auto rounded-2xl border border-rose-300/20 bg-black/45 p-4 text-xs text-rose-50">{communitiesError instanceof Error ? communitiesError.stack ?? communitiesError.message : String(communitiesError)}</pre>
        )}
      </div>
    ) : (
    <div class="mt-5 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {communities.length ? communities.map((community) => (
        <article class="group panel relative overflow-hidden rounded-3xl border-white/15 transition hover:-translate-y-1 hover:border-white/40">
          <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-white/15 via-white/5 to-transparent opacity-60"></div>
          <div class="h-28 bg-cover bg-center sm:h-32" style={`background-image:linear-gradient(180deg,rgba(0,0,0,.2),rgba(0,0,0,.82)),url('${community.bannerUrl ?? 'https://images.unsplash.com/photo-1517927033932-b3d18e61fb3a?auto=format&fit=crop&w=900&q=80'}')`} />
          <div class="p-4 sm:p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <img src={community.logoUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${community.displayName}`} alt={`${community.displayName} logo`} loading="lazy" decoding="async" class="h-10 w-10 rounded-xl border border-white/20 bg-black/40 object-cover sm:h-11 sm:w-11" />
                <div>
                  <h2 class="font-display text-xl sm:text-2xl">{community.displayName}</h2>
                  <p class="text-[11px] uppercase tracking-[0.15em] text-slate-400">{community.region} · {community.platformFocus ?? 'Cross-platform'}</p>
                </div>
              </div>
              <div class="flex flex-wrap justify-end gap-2">
                {community.verified && <span class="rounded-full border border-cyan-300/35 bg-cyan-500/20 px-2 py-1 text-[10px] uppercase tracking-[0.16em] text-cyan-100">Verified</span>}
                {community.featured && <span class="rounded-full border border-amber-300/35 bg-amber-500/20 px-2 py-1 text-[10px] uppercase tracking-[0.16em] text-amber-100">Featured</span>}
              </div>
            </div>
            <p class="mt-3 text-sm text-slate-200">{community.shortDescription ?? community.description ?? 'Structured racing community with active organiser staffing.'}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {(community.tags ?? []).slice(0, 4).map((tag) => <span class="rounded-full border border-white/10 bg-white/[0.05] px-2 py-1 text-xs text-slate-300">{tag}</span>)}
            </div>

            {community.raceSlots?.length ? (
              <div class="mt-4 rounded-2xl border border-white/10 bg-black/35 p-3">
                <p class="text-[10px] uppercase tracking-[0.15em] text-slate-500">Next published events</p>
                <div class="mt-2 space-y-2">
                  {community.raceSlots.map((event) => (
                    <p class="text-xs text-slate-200">{event.title} · {new Date(event.scheduledAt).toLocaleDateString()} · {event._count.registrations}/{event.maxPlayers}</p>
                  ))}
                </div>
              </div>
            ) : (
              <p class="mt-4 rounded-2xl border border-white/10 bg-black/35 px-3 py-2 text-xs text-slate-400">No published events yet.</p>
            )}

            <div class="mt-4 grid grid-cols-2 gap-2 text-sm">
              <p class="rounded-xl border border-white/10 bg-black/35 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.12em] text-slate-500">Members</span>{community.displayedMemberCount.toLocaleString()} <span class="text-[10px] text-slate-500">members · {community.memberCountSource}</span></p>
              <p class="rounded-xl border border-white/10 bg-black/35 px-3 py-2"><span class="block text-[11px] uppercase tracking-[0.12em] text-slate-500">Active events</span>{community._count.raceSlots}</p>
            </div>
            <div class="mt-4 grid gap-2 sm:grid-cols-2">
              <a href={`/communities/${community.slug}`} class="rounded-full bg-white px-4 py-2 text-center text-xs font-semibold uppercase tracking-[0.16em] text-black">View Community</a>
              <button type="button" data-community-join={community.slug} class="rounded-full border border-emerald-300/35 bg-emerald-500/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-emerald-100">Join Community</button>
              {safeExternalUrl(community.discordUrl) && <a href={safeExternalUrl(community.discordUrl)!} target="_blank" rel="noreferrer noopener" class="rounded-full border border-indigo-300/35 bg-indigo-500/15 px-4 py-2 text-center text-xs uppercase tracking-[0.16em] text-indigo-100">Join Discord</a>}
              {safeExternalUrl(community.redditUrl) && <a href={safeExternalUrl(community.redditUrl)!} target="_blank" rel="noreferrer noopener" class="rounded-full border border-orange-300/35 bg-orange-500/15 px-4 py-2 text-center text-xs uppercase tracking-[0.16em] text-orange-100">Join Reddit</a>}
            </div>
          </div>
        </article>
      )) : <p class="panel rounded-2xl p-6 text-slate-300">No communities are public yet.</p>}
    </div>
    )}
  </section>
  <script>
    const joinButtons = document.querySelectorAll<HTMLButtonElement>('[data-community-join]');

    const setButton = (button: HTMLButtonElement, label: string, disabled = false) => {
      button.textContent = label;
      button.disabled = disabled;
      button.classList.toggle('opacity-60', disabled);
    };

    joinButtons.forEach((button) => {
      const slug = button.dataset.communityJoin;
      if (!slug) return;

      fetch(`/api/communities/${slug}/membership`, { credentials: 'include' })
        .then(async (response) => {
          if (response.status === 401) return null;
          if (!response.ok) throw new Error('Unable to check membership');
          return response.json();
        })
        .then((state) => {
          if (!state) return;
          if (state.isOwner) {
            setButton(button, 'Manage Community');
            button.addEventListener('click', () => { window.location.href = '/dashboard/community'; }, { once: true });
            return;
          }
          if (state.member?.status === 'ACTIVE') setButton(button, 'Joined', true);
          if (state.member?.status === 'BANNED') setButton(button, 'Unable to join', true);
        })
        .catch(() => undefined);

      button.addEventListener('click', async () => {
        if (button.disabled || button.textContent === 'Manage Community') return;
        setButton(button, 'Joining...', true);
        try {
          const response = await fetch(`/api/communities/${slug}/join`, {
            method: 'POST',
            credentials: 'include',
            headers: { 'content-type': 'application/json' },
          });
          if (response.status === 401) {
            window.location.href = `/login?redirect=/communities/${slug}`;
            return;
          }
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) throw new Error(payload.error ?? 'Unable to join community');
          setButton(button, 'Joined', true);
        } catch (error) {
          setButton(button, error instanceof Error ? error.message : 'Unable to join', false);
        }
      });
    });
  </script>
</BaseLayout>
