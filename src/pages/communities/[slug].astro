---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSessionUser } from '@/lib/auth/session';
import { privateNoStore, setAstroCache } from '@/lib/server/cache-control';
import { prisma } from '@/lib/db/prisma';
import { getCommunityMemberCountDisplay, getPublicUpcomingRaceSlotWhere } from '@/server/services/community.service';
import { getCommunityMembership } from '@/lib/server/community-permissions';
import { getHonourGrade } from '@/lib/honour';
import { getCommunityRankings, type CommunityRankingView } from '@/server/services/community-rating.service';
import { shouldLogPerf, withPerf } from '@/lib/utils/perf';

export const prerender = false;

// This page is public, but it can include membership-only race sections for signed-in viewers.
// Keep it no-store so personalised community-only data is never publicly cached.
setAstroCache(Astro, privateNoStore);

const routeStart = performance.now();
const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/communities');

const safeExternalUrl = (url?: string | null) => {
  if (!url) return null;
  try {
    const parsed = new URL(url);
    return ['http:', 'https:'].includes(parsed.protocol) ? parsed.toString() : null;
  } catch {
    return null;
  }
};

const raceSelect = {
  id: true,
  title: true,
  track: true,
  visibility: true,
  scheduledAt: true,
  status: true,
  maxPlayers: true,
  platform: true,
  game: true,
  crossplay: true,
  registrationCutoffAt: true,
  league: { select: { id: true, name: true, slug: true } },
  _count: { select: { registrations: true } },
} as const;

const community = await withPerf('community.detail', () => prisma.organiserProfile.findFirst({
  where: { slug, isPublic: true },
  include: {
    user: { select: { id: true, username: true, honourScore: true, avatarUrl: true } },
    leagues: {
      where: { active: true },
      select: { id: true, name: true, slug: true, region: true },
      orderBy: { createdAt: 'desc' },
      take: 4,
    },
    _count: { select: { members: { where: { status: 'ACTIVE' } } } },
  },
}));

if (!community) {
  Astro.response.status = 404;
}

const currentUser = community ? await withPerf('community.session', () => getSessionUser(Astro as never)) : null;
const membership = community && currentUser ? await withPerf('community.membership', () => getCommunityMembership(currentUser.id, community.id)) : null;
const canSeeCommunityOnly = Boolean(
  community &&
  currentUser &&
  (currentUser.role === 'ADMIN' || currentUser.id === community.userId || membership?.status === 'ACTIVE'),
);

const now = new Date();
const rankingViews = ['sr', 'honour', 'clean', 'movers'] as const;
const requestedRankingView = Astro.url.searchParams.get('ranking') as CommunityRankingView | null;
const rankingView = requestedRankingView && rankingViews.includes(requestedRankingView) ? requestedRankingView : 'sr';
const [publicRaces, communityOnlyRaces, recentRaces, communityDuels, communityRankings] = community
  ? await withPerf('community.raceLists', () => Promise.all([
      prisma.raceSlot.findMany({
        where: { ...getPublicUpcomingRaceSlotWhere(), organiserProfileId: community.id },
        select: raceSelect,
        orderBy: { scheduledAt: 'asc' },
        take: 8,
      }),
      canSeeCommunityOnly
        ? prisma.raceSlot.findMany({
            where: {
              organiserProfileId: community.id,
              visibility: 'COMMUNITY_ONLY',
              status: { in: ['OPEN', 'FULL', 'LOCKED'] },
              scheduledAt: { gte: now },
            },
            select: raceSelect,
            orderBy: { scheduledAt: 'asc' },
            take: 8,
          })
        : Promise.resolve([]),
      prisma.raceSlot.findMany({
        where: {
          organiserProfileId: community.id,
          visibility: 'PUBLIC',
          OR: [{ scheduledAt: { lt: now } }, { status: { in: ['COMPLETED', 'CANCELLED'] } }],
          NOT: { status: 'DRAFT' },
        },
        select: raceSelect,
        orderBy: { scheduledAt: 'desc' },
        take: 4,
      }),
      prisma.duel.findMany({
        where: {
          communityId: community.id,
          visibility: canSeeCommunityOnly ? { in: ['PUBLIC', 'COMMUNITY_ONLY'] } : 'PUBLIC',
          status: { in: ['OPEN', 'ACCEPTED', 'IN_PROGRESS', 'COMPLETED'] },
        },
        select: { id: true, status: true, track: true, game: true, ranked: true, scheduledAt: true, createdBy: { select: { username: true } }, opponent: { select: { username: true } } },
        orderBy: [{ status: 'asc' }, { updatedAt: 'desc' }],
        take: 6,
      }),
      getCommunityRankings(community.slug, rankingView, 10),
    ]))
  : [[], [], [], [], null];

const memberDisplay = community ? getCommunityMemberCountDisplay(community) : { count: 0, source: 'racehub' };
const raceHubMembers = community?._count.members ?? 0;
const externalSource = community && ['discord', 'reddit'].includes(community.memberCountSource.toLowerCase()) ? community.memberCountSource.toLowerCase() : null;
const externalCount = externalSource && community.displayedMemberCount > 0 ? community.displayedMemberCount : null;
const discordUrl = safeExternalUrl(community?.discordUrl);
const redditUrl = safeExternalUrl(community?.redditUrl);
const websiteUrl = safeExternalUrl(community?.websiteUrl);
const accent = community?.brandingColor || '#38bdf8';

if (shouldLogPerf()) console.info(`[perf] community.routeTotal: ${(performance.now() - routeStart).toFixed(1)}ms`);

const RaceCard = (event: (typeof publicRaces)[number]) => {
  const filled = Math.min(100, Math.round((event._count.registrations / event.maxPlayers) * 100));
  return { event, filled };
};

const formatDelta = (value: number) => value > 0 ? `+${value}` : String(value);
---

<BaseLayout title={community ? `${community.displayName} | RaceHub` : 'Community not found | RaceHub'}>
  {community ? (
    <section class="section-shell pb-28 md:pb-24">
      <article class="panel overflow-hidden rounded-3xl border-white/15">
        <div class="relative min-h-[20rem] bg-cover bg-center md:min-h-[18rem]" style={`background-image:linear-gradient(180deg,rgba(2,6,23,.18),rgba(2,6,23,.92)),url('${community.bannerUrl ?? '/pictures/communititesback.webp'}')`}>
          <div class="absolute inset-0" style={`background: radial-gradient(circle at 18% 20%, ${accent}33, transparent 34%), linear-gradient(90deg, rgba(0,0,0,.68), transparent 62%)`}></div>
          <div class="relative mx-auto flex min-h-[20rem] w-[min(1120px,94%)] flex-col justify-end gap-5 pb-6 pt-24 md:min-h-[18rem] lg:flex-row lg:items-end lg:justify-between">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
              <img src={community.logoUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${community.displayName}`} class="h-20 w-20 rounded-3xl border border-white/25 bg-black/45 object-cover shadow-2xl sm:h-24 sm:w-24" alt={`${community.displayName} logo`} />
              <div>
                <div class="flex flex-wrap gap-2">
                  {community.verified && <span class="rh-badge rounded-full border border-cyan-300/35 bg-cyan-500/20 px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-cyan-100">Verified</span>}
                  {community.featured && <span class="rh-badge rounded-full border border-amber-300/35 bg-amber-500/20 px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-amber-100">Featured</span>}
                </div>
                <h1 class="mt-3 font-display text-4xl text-white md:text-6xl">{community.displayName}</h1>
                <p class="mt-2 max-w-2xl text-sm text-slate-200 line-clamp-2 md:line-clamp-none">{community.shortDescription ?? 'A RaceHub organiser community.'}</p>
                <p class="mt-2 text-xs uppercase tracking-[0.18em] text-slate-300">{community.region} · {community.platformFocus ?? 'Cross-platform'} · {community.gameFocus ?? 'F1'}</p>
              </div>
            </div>
            <div class="grid w-full gap-2 sm:w-auto sm:grid-cols-2 lg:min-w-80">
              <button type="button" data-community-join={community.slug} class="rounded-full bg-white px-5 py-3 text-xs font-semibold uppercase tracking-[0.16em] text-black">Join Community</button>
              {discordUrl && <a href={discordUrl} target="_blank" rel="noopener noreferrer" class="rh-badge rounded-full border border-indigo-300/35 bg-indigo-500/15 px-5 py-3 text-center text-xs uppercase tracking-[0.16em] text-indigo-100">Join Discord</a>}
              {redditUrl && <a href={redditUrl} target="_blank" rel="noopener noreferrer" class="rh-badge rounded-full border border-orange-300/35 bg-orange-500/15 px-5 py-3 text-center text-xs uppercase tracking-[0.16em] text-orange-100">Join Reddit</a>}
              {websiteUrl && <a href={websiteUrl} target="_blank" rel="noopener noreferrer" class="rh-badge rounded-full border border-white/20 bg-white/10 px-5 py-3 text-center text-xs uppercase tracking-[0.16em] text-white">Website</a>}
            </div>
          </div>
        </div>

        <div class="grid gap-6 p-5 md:p-8 lg:grid-cols-[1.35fr_.65fr]">
          <div>
            <h2 class="font-display text-2xl text-white">Community hub</h2>
            <p class="mt-3 whitespace-pre-line text-sm leading-7 text-slate-300 line-clamp-4 md:line-clamp-none">{community.description ?? community.shortDescription ?? 'This organiser has not added a long-form community description yet.'}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {(community.tags ?? []).slice(0, 3).map((tag) => <span class="rh-badge rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-slate-300">{tag}</span>)}
            </div>
            {community.credibilityNotes && <div class="mt-5 rounded-2xl border border-white/10 bg-black/30 p-4 text-sm text-slate-300"><p class="text-xs uppercase tracking-[0.18em] text-slate-500">Community rules / notes</p><p class="mt-2 whitespace-pre-line">{community.credibilityNotes}</p></div>}
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            <div class="rounded-2xl border border-white/10 bg-black/30 p-4"><p class="text-xs uppercase tracking-[0.16em] text-slate-500">RaceHub members</p><p class="mt-2 font-display text-4xl">{raceHubMembers.toLocaleString()}</p></div>
            {externalCount && <div class="rounded-2xl border border-white/10 bg-black/30 p-4"><p class="text-xs uppercase tracking-[0.16em] text-slate-500">{externalSource} members</p><p class="mt-2 font-display text-4xl">{externalCount.toLocaleString()}</p><p class="text-[11px] text-slate-500">Cached count{community.memberCountLastSyncedAt ? ` · synced ${new Date(community.memberCountLastSyncedAt).toLocaleDateString()}` : ''}</p></div>}
            {!externalCount && <div class="rounded-2xl border border-white/10 bg-black/30 p-4"><p class="text-xs uppercase tracking-[0.16em] text-slate-500">Displayed members</p><p class="mt-2 font-display text-4xl">{memberDisplay.count.toLocaleString()}</p><p class="text-[11px] text-slate-500">Source: {memberDisplay.source}</p></div>}
            <div class="rounded-2xl border border-white/10 bg-black/30 p-4"><p class="text-xs uppercase tracking-[0.16em] text-slate-500">Operated by</p><p class="mt-2 text-lg font-semibold">@{community.user.username}</p><p class="text-xs text-slate-500">Honour {community.user.honourScore}</p></div>
          </div>
        </div>
      </article>

      <article id="rankings" class="panel mt-8 rounded-3xl p-5 md:p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-emerald-100/70">SR / Honour / Clean driving</p>
            <h2 class="font-display text-2xl">Community rankings</h2>
            <p class="mt-2 max-w-2xl text-sm text-slate-400">A community-specific reputation table for drivers who race here, separate from the global RaceHub rating.</p>
          </div>
          <nav class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap" aria-label="Community ranking views">
            {rankingViews.map((view) => (
              <a href={`/communities/${community.slug}?ranking=${view}#rankings`} class={`rounded-full border px-4 py-2 text-center text-xs uppercase tracking-[0.14em] transition ${rankingView === view ? 'border-white/45 bg-white text-black' : 'border-white/15 bg-white/[0.04] text-slate-200 hover:border-white/35'}`}>
                {view === 'sr' ? 'SR' : view === 'honour' ? 'Honour' : view === 'clean' ? 'Clean' : 'Movers'}
              </a>
            ))}
          </nav>
        </div>

        <div class="mt-5 space-y-2">
          {communityRankings?.rows.length ? communityRankings.rows.map((row) => {
            const grade = getHonourGrade(row.honourScore);
            return (
              <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.035] p-3 sm:grid-cols-[auto_1fr_auto_auto_auto]">
                <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 bg-black/35 text-sm font-semibold text-white">#{row.rank}</span>
                <div class="flex min-w-0 items-center gap-3">
                  <img src={row.user.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${row.user.username}`} alt="" class="h-10 w-10 rounded-full border border-white/10 object-cover" />
                  <div class="min-w-0">
                    <p class="truncate font-semibold text-white">{row.user.username}</p>
                    <p class="text-xs text-slate-500">{row.starts} starts · {row.wins} wins · {row.cleanRaceRatio}% clean</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="font-display text-2xl text-white">{row.skillRating}</p>
                  <p class="text-[10px] uppercase tracking-[0.16em] text-slate-500">SR</p>
                </div>
                <span class={`hidden rounded-full border px-3 py-1 text-xs font-semibold sm:inline-flex ${grade.tone}`}>{grade.label}</span>
                <span class={`hidden text-sm font-semibold sm:block ${row.recentSkillDelta >= 0 ? 'text-emerald-200' : 'text-rose-200'}`}>{formatDelta(row.recentSkillDelta)}</span>
              </div>
            );
          }) : (
            <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No community rating rows yet. Submit race results to start building this table.</p>
          )}
        </div>
      </article>

      <div class="mt-8 grid gap-5 xl:grid-cols-2">
        <article class="panel rounded-3xl p-5 md:p-6">
          <h2 class="font-display text-2xl">Public races</h2>
          <div class="mt-4 space-y-3">
            {publicRaces.length ? publicRaces.map((race) => {
              const { event, filled } = RaceCard(race);
              return <a href={`/race-slots/${event.id}`} class="block rounded-2xl border border-white/10 bg-white/[0.035] p-4 transition hover:border-white/35">
                <div class="flex items-start justify-between gap-3"><div><p class="text-xs uppercase tracking-[0.16em] text-slate-500">{event.league.name} · {event.game} · {event.platform ?? 'Cross-platform'}</p><h3 class="mt-1 font-semibold text-white">{event.title}</h3></div><span class="rh-badge rounded-full border border-emerald-300/35 bg-emerald-500/15 px-3 py-1 text-[10px] uppercase tracking-[0.16em] text-emerald-100">{event.visibility}</span></div>
                <p class="mt-2 text-sm text-slate-300">{event.track ?? 'Track TBA'} · {new Date(event.scheduledAt).toLocaleString()}</p>
                <div class="mt-3 h-2 rounded-full bg-white/10"><div class="h-full rounded-full bg-gradient-to-r from-emerald-300 to-cyan-200" style={`width:${filled}%`}></div></div>
                <p class="mt-2 text-xs text-slate-400">{event._count.registrations}/{event.maxPlayers} registered · View details</p>
              </a>;
            }) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No public upcoming races are listed yet.</p>}
          </div>
        </article>

        <article class="panel rounded-3xl p-5 md:p-6">
          <h2 class="font-display text-2xl">Community-only races</h2>
          <div class="mt-4 space-y-3">
            {canSeeCommunityOnly ? (
              communityOnlyRaces.length ? communityOnlyRaces.map((race) => {
                const { event, filled } = RaceCard(race);
                return <a href={`/race-slots/${event.id}`} class="block rounded-2xl border border-violet-300/20 bg-violet-500/[0.06] p-4 transition hover:border-violet-200/45">
                  <div class="flex items-start justify-between gap-3"><div><p class="text-xs uppercase tracking-[0.16em] text-violet-100/70">{event.league.name} · {event.game} · {event.platform ?? 'Cross-platform'}</p><h3 class="mt-1 font-semibold text-white">{event.title}</h3></div><span class="rh-badge rounded-full border border-violet-300/35 bg-violet-500/15 px-3 py-1 text-[10px] uppercase tracking-[0.16em] text-violet-100">Members</span></div>
                  <p class="mt-2 text-sm text-slate-300">{event.track ?? 'Track TBA'} · {new Date(event.scheduledAt).toLocaleString()}</p>
                  <div class="mt-3 h-2 rounded-full bg-white/10"><div class="h-full rounded-full bg-gradient-to-r from-violet-300 to-fuchsia-200" style={`width:${filled}%`}></div></div>
                  <p class="mt-2 text-xs text-slate-400">{event._count.registrations}/{event.maxPlayers} registered · View details</p>
                </a>;
              }) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No member-only upcoming races are listed yet.</p>
            ) : (
              <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">
                <p class="font-semibold text-white">Join this RaceHub community to see member-only races.</p>
                <p class="mt-1 text-slate-400">Public visitors only see public race slots.</p>
              </div>
            )}
          </div>
        </article>
      </div>


      <article id="races" class="panel mt-8 rounded-3xl p-5 md:p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Community 1v1 arena</p>
            <h2 class="font-display text-2xl">Hosted Duels</h2>
          </div>
          <a href="/duels/new" class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.16em] text-slate-200 transition hover:border-white/40 hover:bg-white/10">Create community duel</a>
        </div>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          {communityDuels.length ? communityDuels.map((duel) => (
            <a href={`/duels/${duel.id}`} class="rounded-2xl border border-cyan-300/15 bg-cyan-500/[0.06] p-4 transition hover:border-cyan-200/45">
              <p class="text-xs uppercase tracking-[0.16em] text-cyan-100/70">{duel.game} · {duel.status.replaceAll('_', ' ')}</p>
              <h3 class="mt-1 font-semibold text-white">{duel.createdBy.username} vs {duel.opponent?.username ?? 'Open opponent'}</h3>
              <p class="mt-1 text-sm text-slate-300">{duel.track} · {duel.ranked ? 'Ranked' : 'Unranked'} · {duel.scheduledAt ? new Date(duel.scheduledAt).toLocaleString() : 'Open challenge'}</p>
            </a>
          )) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300 md:col-span-2">No community duels are listed yet.</p>}
        </div>
      </article>


      <div class="fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-black/80 px-4 py-3 backdrop-blur-xl mobile-safe-bottom md:hidden">
        <div class="mx-auto grid max-w-md grid-cols-2 gap-2">
          <button type="button" data-community-join={community.slug} class="min-h-12 rounded-2xl bg-white px-4 text-sm font-bold text-black">Join</button>
          <a href="#races" class="flex min-h-12 items-center justify-center rounded-2xl border border-white/15 bg-white/10 px-4 text-sm font-bold text-white">Active races</a>
        </div>
      </div>

      <article class="panel mt-8 rounded-3xl p-5 md:p-6">
        <h2 class="font-display text-2xl">Recent events</h2>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          {recentRaces.length ? recentRaces.map((event) => (
            <a href={`/race-slots/${event.id}`} class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-white/35">
              <p class="text-xs uppercase tracking-[0.16em] text-slate-500">{event.status} · {event.track ?? 'Track TBA'}</p>
              <h3 class="mt-1 font-semibold text-white">{event.title}</h3>
              <p class="mt-1 text-sm text-slate-300">{new Date(event.scheduledAt).toLocaleDateString()} · {event._count.registrations} entrants</p>
            </a>
          )) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No recent public events yet.</p>}
        </div>
      </article>
    </section>
  ) : (
    <section class="section-shell pb-28 md:pb-24">
      <div class="panel rounded-3xl p-8">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">404</p>
        <h1 class="section-title mt-2">Community not found</h1>
        <p class="mt-3 text-slate-300">This community is not public or does not exist.</p>
        <a href="/communities" class="mt-5 inline-flex rounded-full bg-white px-5 py-3 text-sm font-semibold text-black">Back to communities</a>
      </div>
    </section>
  )}

  <script>
    const button = document.querySelector<HTMLButtonElement>('[data-community-join]');
    const setButton = (label: string, disabled = false) => {
      if (!button) return;
      button.textContent = label;
      button.disabled = disabled;
      button.classList.toggle('opacity-60', disabled);
    };

    if (button) {
      const slug = button.dataset.communityJoin;
      fetch(`/api/communities/${slug}/membership`, { credentials: 'include' })
        .then(async (response) => {
          if (response.status === 401) return null;
          if (!response.ok) throw new Error('Unable to check membership');
          return response.json();
        })
        .then((state) => {
          if (!state) return;
          if (state.isOwner) setButton('Manage Community');
          else if (state.member?.status === 'ACTIVE') setButton('Joined', true);
          else if (state.member?.status === 'BANNED') setButton('Unable to join', true);
        })
        .catch(() => undefined);

      button.addEventListener('click', async () => {
        if (button.textContent === 'Manage Community') {
          window.location.href = '/dashboard/community';
          return;
        }
        if (button.disabled) return;
        setButton('Joining...', true);
        try {
          const response = await fetch(`/api/communities/${slug}/join`, { method: 'POST', credentials: 'include', headers: { 'content-type': 'application/json' } });
          if (response.status === 401) {
            window.location.href = `/login?redirect=/communities/${slug}`;
            return;
          }
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) throw new Error(payload.error ?? 'Unable to join community');
          setButton('Joined', true);
        } catch (error) {
          setButton(error instanceof Error ? error.message : 'Unable to join', false);
        }
      });
    }
  </script>
</BaseLayout>
