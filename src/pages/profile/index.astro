---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { privateNoStore, setAstroCache } from '@/lib/server/cache-control';
import ProfileOverview from '@/components/profile/ProfileOverview';
import { getSessionUser } from '@/lib/auth/session';
import { shouldLogPerf, withPerf } from '@/lib/utils/perf';

export const prerender = false;

// Private personalised route: dashboard/profile/admin HTML must never be public cached.
setAstroCache(Astro, privateNoStore);

const routeStart = performance.now();
const user = await withPerf('profile.session', () => getSessionUser(Astro as never));
if (!user) return Astro.redirect('/login');

const shellReadyAt = performance.now();

if (shouldLogPerf()) {
  console.info(`[perf] profile.shell: ${(shellReadyAt - routeStart).toFixed(1)}ms`);
  console.info(`[perf] profile.total: ${(performance.now() - routeStart).toFixed(1)}ms`);
}
---
<BaseLayout title="Profile | RaceHub" noindex={true} sessionUser={user} lightweightApp={true}>
  <section class="section-shell racehub-profile-shell">
    <div class="profile-frame p-5 md:p-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="flex items-center gap-4 md:items-start">
          <img src={user.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${user.username}`} alt={`${user.username} avatar`} width="96" height="96" loading="eager" decoding="async" class="h-20 w-20 rounded-2xl border border-white/20 bg-black/30 object-cover md:h-24 md:w-24" />
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Driver Identity</p>
            <h1 class="mt-1 font-display text-4xl">{user.username}</h1>
            <p class="mt-1 text-xs uppercase tracking-[0.18em] text-slate-400">{user.region ?? 'GLOBAL'} · {user.preferredPlatform ?? 'Platform TBD'}</p>
            <p class="mt-3 hidden max-w-2xl text-sm text-slate-300 md:block">{user.bio ?? 'No bio added yet. Add your racecraft profile and preferred style.'}</p>
          </div>
        </div>
        <a href="/profile/edit" class="edit-btn">Settings</a>
      </div>
    </div>

    <ProfileOverview client:load />
  </section>
</BaseLayout>
<style>
.racehub-profile-shell{background:linear-gradient(180deg,#0d1218,#111821 55%,#17212b);padding:24px;border:1px solid rgba(180,200,190,.16);box-shadow:inset 0 1px 0 rgba(255,255,255,.05);max-width:1280px;margin:0 auto;}
.profile-frame{border:1px solid rgba(180,200,190,.16);background:linear-gradient(180deg,#2a333d,#1c242d);box-shadow:inset 0 1px 0 rgba(255,255,255,.08),0 12px 24px rgba(0,0,0,.28)}
.edit-btn{border:1px solid rgba(255,145,70,.75);color:#f4f7f5;padding:10px 16px;text-transform:uppercase;letter-spacing:.12em}
</style>