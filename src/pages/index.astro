---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroScene from '@/components/sections/HeroScene';
import SlotShowcase from '@/components/sections/SlotShowcase';
import HowItWorksTimeline from '@/components/sections/HowItWorksTimeline';
import LeaderboardPreview from '@/components/sections/LeaderboardPreview';
import HonourSystem from '@/components/sections/HonourSystem';
import OrganiserShowcase from '@/components/sections/OrganiserShowcase.astro';
import FeatureStrip from '@/components/sections/FeatureStrip';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { fetchFromApi } from '@/lib/server-api';
import type { CommunitySummary, RaceSlotSummary } from '@/lib/api/types';
import type { PublicUser } from '@/server/types/api';

export const prerender = false;

const slotsResponse = await fetchFromApi<{ raceSlots: RaceSlotSummary[] }>(Astro, '/api/race-slots?status=OPEN&limit=6').catch(
  () => ({ raceSlots: [] }),
);
const communitiesResponse = await fetchFromApi<{ communities: CommunitySummary[] }>(Astro, '/api/communities?featured=1&limit=3').catch(
  () => ({ communities: [] }),
);
const globalLb = await fetchFromApi<{ leaderboard: PublicUser[] }>(Astro, '/api/leaderboards/global?limit=8').catch(() => ({ leaderboard: [] }));
const honourLb = await fetchFromApi<{ leaderboard: PublicUser[] }>(Astro, '/api/leaderboards/honour?limit=8').catch(() => ({ leaderboard: [] }));
---

<BaseLayout>
  <HeroScene client:load />
  <SlotShowcase client:idle raceSlots={slotsResponse.raceSlots} />

  <section class="section-shell pt-0" data-reveal>
    <div class="panel rounded-3xl p-6 md:p-8">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Featured communities</p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl">Join organiser programs with active race pipelines.</h2>
        </div>
        <a href="/communities" class="rounded-full border border-white/20 bg-white/5 px-5 py-2 text-xs uppercase tracking-[0.18em] transition hover:border-white/40 hover:bg-white/10">Browse all communities</a>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {communitiesResponse.communities.length ? communitiesResponse.communities.map((community) => (
          <a href={`/communities/${community.slug}`} class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-white/35 hover:bg-white/[0.06]">
            <div class="flex items-center gap-3">
              <img src={community.logoUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${community.displayName}`} alt={`${community.displayName} logo`} class="h-10 w-10 rounded-xl border border-white/10 object-cover" />
              <div>
                <p class="font-semibold text-white">{community.displayName}</p>
                <p class="text-xs text-slate-400">{community.region} · {community.platformFocus ?? 'Crossplay'}</p>
              </div>
            </div>
            <p class="mt-3 text-sm text-slate-300">{community.shortDescription ?? community.description ?? 'Organiser-led race community.'}</p>
            <p class="mt-3 text-xs uppercase tracking-[0.14em] text-slate-500">{community.displayedMemberCount.toLocaleString()} members · {community._count.raceSlots} active events</p>
          </a>
        )) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">Featured communities are loading.</p>}
      </div>
    </div>
  </section>

  <HowItWorksTimeline client:visible />
  <LeaderboardPreview client:visible globalLeaderboard={globalLb.leaderboard} honourLeaderboard={honourLb.leaderboard} />
  <HonourSystem client:visible />
  <OrganiserShowcase />
  <FeatureStrip client:visible />
  <FinalCTA />
</BaseLayout>
