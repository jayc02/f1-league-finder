---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroScene from '@/components/sections/HeroScene';
import SlotShowcase from '@/components/sections/SlotShowcase';
import LeaderboardPreview from '@/components/sections/LeaderboardPreview';
import HonourSystem from '@/components/sections/HonourSystem';
import OrganiserShowcase from '@/components/sections/OrganiserShowcase.astro';
import FeatureStrip from '@/components/sections/FeatureStrip';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { getPublicCommunitySummaries } from '@/server/services/community.service';
import { getPublicRaceSlotSummaries } from '@/server/services/race-slot.service';
import { getGlobalSkillLeaderboard, getHonourLeaderboard } from '@/server/services/leaderboard.service';
import { shouldLogPerf, withPerf } from '@/lib/utils/perf';
import { absoluteUrl } from '@/lib/config';
import { publicPageMedium, setAstroCache } from '@/lib/server/cache-control';

export const prerender = false;

// Public cached route: homepage renders only public listings and leaderboard previews.
setAstroCache(Astro, publicPageMedium);

const [raceSlots, featuredCommunities, globalLeaderboard, honourLeaderboard] = await Promise.all([
  withPerf('home.raceSlots', () => getPublicRaceSlotSummaries({ status: 'OPEN', limit: 6 })),
  withPerf('home.communities.featured', () => getPublicCommunitySummaries({ featuredOnly: true, limit: 3 })),
  withPerf('home.leaderboard.global', () => getGlobalSkillLeaderboard(8)),
  withPerf('home.leaderboard.honour', () => getHonourLeaderboard(8)),
]);

const fallbackCommunities = featuredCommunities.length
  ? []
  : await withPerf('home.communities.fallback', () => getPublicCommunitySummaries({ limit: 3 }));
const showcaseCommunities = featuredCommunities.length ? featuredCommunities : fallbackCommunities;
const showingFeaturedCommunities = featuredCommunities.length > 0;
if (shouldLogPerf()) console.info('[perf] home.selfFetchRemoved: true');

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RaceHub',
  url: absoluteUrl('/'),
  potentialAction: {
    '@type': 'SearchAction',
    target: `${absoluteUrl('/race-slots')}?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="RaceHub | Competitive Sim Racing Platform"
  description="Discover competitive race slots, verified communities, and transparent global rankings on RaceHub.gg."
  canonicalPath="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <HeroScene client:idle />
  <SlotShowcase client:idle raceSlots={raceSlots} />

  <section class="section-shell pt-0" data-reveal>
    <div class="panel rounded-3xl p-6 md:p-8">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{showingFeaturedCommunities ? 'Featured communities' : 'Latest public communities'}</p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl">{showingFeaturedCommunities ? 'Join featured organiser programs with active race pipelines.' : 'Discover public organiser programs while featured spotlights are being curated.'}</h2>
        </div>
        <a href="/communities" class="rounded-full border border-white/20 bg-white/5 px-5 py-2 text-xs uppercase tracking-[0.18em] transition hover:border-white/40 hover:bg-white/10">Browse all communities</a>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {showcaseCommunities.length ? showcaseCommunities.map((community) => (
          <a href={`/communities/${community.slug}`} class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-white/35 hover:bg-white/[0.06]">
            <div class="flex items-center gap-3">
              <img src={community.logoUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${community.displayName}`} alt={`${community.displayName} logo`} loading="lazy" decoding="async" class="h-10 w-10 rounded-xl border border-white/10 object-cover" />
              <div>
                <p class="font-semibold text-white">{community.displayName}</p>
                <p class="text-xs text-slate-400">{community.region} · {community.platformFocus ?? 'Crossplay'}</p>
              </div>
            </div>
            <p class="mt-3 text-sm text-slate-300">{community.shortDescription ?? community.description ?? 'Organiser-led race community.'}</p>
            <p class="mt-3 text-xs uppercase tracking-[0.14em] text-slate-500">{community.displayedMemberCount.toLocaleString()} members · {community._count.raceSlots} active events</p>
          </a>
        )) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No featured communities are available yet. Browse all public communities to discover new organiser profiles.</p>}
      </div>
    </div>
  </section>

  <LeaderboardPreview client:visible globalLeaderboard={globalLeaderboard} honourLeaderboard={honourLeaderboard} />
  <HonourSystem client:visible />
  <OrganiserShowcase />
  <FeatureStrip client:visible />
  <FinalCTA />
</BaseLayout>
