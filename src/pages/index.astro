---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroScene from '@/components/sections/HeroScene';
import SlotShowcase from '@/components/sections/SlotShowcase';
import LeaderboardPreview from '@/components/sections/LeaderboardPreview';
import HonourSystem from '@/components/sections/HonourSystem';
import OrganiserShowcase from '@/components/sections/OrganiserShowcase.astro';
import FeatureStrip from '@/components/sections/FeatureStrip';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { getPublicCommunitySummaries } from '@/server/services/community.service';
import { getPublicRaceSlotSummaries } from '@/server/services/race-slot.service';
import { getGlobalSkillLeaderboard, getHonourLeaderboard } from '@/server/services/leaderboard.service';
import { shouldLogPerf, withPerf } from '@/lib/utils/perf';
import { absoluteUrl } from '@/lib/config';
import { publicPageMedium, setAstroCache } from '@/lib/server/cache-control';

export const prerender = false;

// Public cached route: homepage renders only public listings and leaderboard previews.
setAstroCache(Astro, publicPageMedium);

const safeHomeData = async <T,>(label: string, loader: () => Promise<T>, fallback: T) => {
  try {
    return await withPerf(label, loader);
  } catch (error) {
    console.warn(`[home] ${label} unavailable`, error);
    return fallback;
  }
};

const [raceSlots, featuredCommunities, globalLeaderboard, honourLeaderboard] = await Promise.all([
  safeHomeData('home.raceSlots', () => getPublicRaceSlotSummaries({ status: 'OPEN', limit: 6 }), []),
  safeHomeData('home.communities.featured', () => getPublicCommunitySummaries({ featuredOnly: true, limit: 3 }), []),
  safeHomeData('home.leaderboard.global', () => getGlobalSkillLeaderboard(8), []),
  safeHomeData('home.leaderboard.honour', () => getHonourLeaderboard(8), []),
]);

const fallbackCommunities = featuredCommunities.length
  ? []
  : await safeHomeData('home.communities.fallback', () => getPublicCommunitySummaries({ limit: 3 }), []);
const showcaseCommunities = featuredCommunities.length ? featuredCommunities : fallbackCommunities;
if (shouldLogPerf()) console.info('[perf] home.selfFetchRemoved: true');

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RaceHub',
  url: absoluteUrl('/'),
  potentialAction: {
    '@type': 'SearchAction',
    target: `${absoluteUrl('/race-slots')}?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="RaceHub | Ranked 1v1 Racing Challenges"
  description="Create and accept 1v1 racing challenges, confirm results, build your rating, and climb the RaceHub leaderboard."
  canonicalPath="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <HeroScene client:idle />
  <SlotShowcase client:idle raceSlots={raceSlots} />

  <section class="section-shell pt-0" data-reveal>
    <div class="panel rounded-3xl p-6 md:p-8">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Community ladders</p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl">Communities</h2><p class="mt-2 text-sm text-slate-300 md:hidden">Join active clubs and race tonight.</p><h2 class="mt-2 hidden font-display text-4xl md:block">Clubs host 1v1 nights, ranked challenges, and private ladders.</h2>
        </div>
        <a href="/communities" class="flex min-h-11 items-center justify-center rounded-full border border-white/20 bg-white/5 px-5 text-xs uppercase tracking-[0.14em] transition hover:border-white/40 hover:bg-white/10 md:tracking-[0.18em]">Browse communities</a>
      </div>
      <div class="mobile-scroll-row mt-6 md:grid md:gap-4 md:overflow-visible md:grid-cols-3">
        {showcaseCommunities.length ? showcaseCommunities.map((community) => (
          <a href={`/communities/${community.slug}`} class="mobile-scroll-card rounded-2xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-white/35 hover:bg-white/[0.06] md:min-w-0">
            <div class="flex items-center gap-3">
              <img src={community.logoUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${community.displayName}`} alt={`${community.displayName} logo`} loading="lazy" decoding="async" class="h-10 w-10 rounded-xl border border-white/10 object-cover" />
              <div>
                <p class="font-semibold text-white">{community.displayName}</p>
                <p class="text-xs text-slate-400">{community.region} · {community.platformFocus ?? 'Crossplay'}</p>
              </div>
            </div>
            <p class="mt-3 text-sm text-slate-300 line-clamp-1 md:line-clamp-2">{community.shortDescription ?? 'Organiser-led 1v1 racing community.'}</p>
            <p class="mt-3 text-xs uppercase tracking-[0.14em] text-slate-500">{community.displayedMemberCount.toLocaleString()} members · {community._count.raceSlots} active challenges</p>
          </a>
        )) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No community ladders are available yet. Browse public communities to find organisers.</p>}
      </div>
    </div>
  </section>

  <LeaderboardPreview client:visible globalLeaderboard={globalLeaderboard} honourLeaderboard={honourLeaderboard} />
  <HonourSystem client:visible />
  <OrganiserShowcase />
  <FeatureStrip client:visible />
  <FinalCTA />
</BaseLayout>
