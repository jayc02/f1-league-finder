---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { privateNoStore, setAstroCache } from '@/lib/server/cache-control';
import AdminShell from '@/components/admin/AdminShell.astro';
import { getSessionUser } from '@/lib/auth/session';
import { getAdminOverview } from '@/server/services/admin.service';
import { shouldLogPerf, withPerf } from '@/lib/utils/perf';

export const prerender = false;

// Private personalised route: dashboard/profile/admin HTML must never be public cached.
setAstroCache(Astro, privateNoStore);

const routeStart = performance.now();
const user = await withPerf('admin.session', () => getSessionUser(Astro as never));
if (!user) return Astro.redirect('/login');
if (user.role !== 'ADMIN') return Astro.redirect('/dashboard');

const [totalUsers, totalEvents, totalCommunities, openDisputes, latestUsers, latestEvents] = await withPerf('admin.overview', () => getAdminOverview());
if (shouldLogPerf()) console.info(`[perf] admin.routeTotal: ${(performance.now() - routeStart).toFixed(1)}ms`);
---

<BaseLayout noindex={true} sessionUser={user} lightweightApp={true} title="Admin Dashboard | RaceHub">
  <section class="section-shell">
    <AdminShell title="Platform Command Center" subtitle="Global management for users, race inventory, communities, and moderation workflows." active="dashboard" />

    <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <article class="panel rounded-2xl p-5"><p class="text-xs uppercase tracking-[0.15em] text-slate-400">Users</p><p class="mt-2 font-display text-3xl">{totalUsers.toLocaleString()}</p></article>
      <article class="panel rounded-2xl p-5"><p class="text-xs uppercase tracking-[0.15em] text-slate-400">Race slots</p><p class="mt-2 font-display text-3xl">{totalEvents.toLocaleString()}</p></article>
      <article class="panel rounded-2xl p-5"><p class="text-xs uppercase tracking-[0.15em] text-slate-400">Communities</p><p class="mt-2 font-display text-3xl">{totalCommunities.toLocaleString()}</p></article>
      <article class="panel rounded-2xl p-5"><p class="text-xs uppercase tracking-[0.15em] text-slate-400">Open disputes</p><p class="mt-2 font-display text-3xl">{openDisputes.toLocaleString()}</p></article>
    </div>

    <div class="mt-6 grid gap-6 xl:grid-cols-2">
      <article class="panel rounded-3xl p-5">
        <div class="flex items-center justify-between"><h2 class="font-display text-2xl">Newest Users</h2><a href="/admin/users" class="text-xs uppercase tracking-[0.15em] text-slate-400 hover:text-white">Manage users</a></div>
        <div class="mt-4 space-y-2">
          {latestUsers.map((item) => <div class="rounded-xl border border-white/10 bg-white/[0.03] p-3"><p class="font-medium text-white">{item.username}</p><p class="text-xs text-slate-400">{item.role} · joined {new Date(item.createdAt).toLocaleDateString()}</p></div>)}
        </div>
      </article>

      <article class="panel rounded-3xl p-5">
        <div class="flex items-center justify-between"><h2 class="font-display text-2xl">Latest Events</h2><a href="/admin/races" class="text-xs uppercase tracking-[0.15em] text-slate-400 hover:text-white">Manage races</a></div>
        <div class="mt-4 space-y-2">
          {latestEvents.map((item) => <div class="rounded-xl border border-white/10 bg-white/[0.03] p-3"><p class="font-medium text-white">{item.title}</p><p class="text-xs text-slate-400">{item.league.name} · {item.status} · {new Date(item.scheduledAt).toLocaleString()}</p></div>)}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
