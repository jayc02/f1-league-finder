---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdminShell from '@/components/admin/AdminShell.astro';
import AdminDisputeManager from '@/components/admin/AdminDisputeManager';
import { getSessionUser } from '@/lib/auth/session';
import { prisma } from '@/lib/db/prisma';

export const prerender = false;

const user = await getSessionUser(Astro as never);
if (!user) return Astro.redirect('/login');
if (user.role !== 'ADMIN') return Astro.redirect('/dashboard');

const disputes = await prisma.dispute.findMany({
  include: {
    openedBy: { select: { id: true, username: true, email: true } },
    resolvedBy: { select: { id: true, username: true } },
    raceSlot: {
      select: {
        id: true,
        title: true,
        organiser: { select: { id: true, username: true, email: true } },
        organiserProfile: { select: { id: true, displayName: true } },
        league: { select: { id: true, name: true } },
      },
    },
    _count: { select: { moderationActions: true, emailLogs: true } },
  },
  orderBy: { createdAt: 'desc' },
  take: 180,
});
---

<BaseLayout noindex={true} title="Admin Disputes | RaceHub">
  <section class="section-shell">
    <AdminShell title="Dispute Command" subtitle="End-to-end dispute moderation including lifecycle control, communication, and immutable operational history." active="disputes" />
    <AdminDisputeManager client:load disputes={disputes.map((item) => ({ ...item, createdAt: item.createdAt.toISOString(), updatedAt: item.updatedAt.toISOString(), resolvedAt: item.resolvedAt?.toISOString() ?? null }))} />
  </section>
</BaseLayout>
