---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---
<BaseLayout noindex={true} title="Reset password | RaceHub">
  <section class="section-shell">
    <form id="reset" class="panel mx-auto w-full max-w-lg rounded-3xl p-6 md:p-8 space-y-4">
      <h1 class="font-display text-3xl text-white">Set a new password</h1>
      <input required type="password" name="password" minlength="8" placeholder="New password" class="w-full rounded-xl border border-white/20 bg-black/40 px-4 py-3 text-white"/>
      <input required type="password" name="confirmPassword" minlength="8" placeholder="Confirm new password" class="w-full rounded-xl border border-white/20 bg-black/40 px-4 py-3 text-white"/>
      <button class="w-full rounded-xl bg-white px-4 py-3 font-semibold text-black">Reset password</button>
      <p id="msg" class="text-sm text-slate-300"></p>
      <a href="/login" class="text-sm text-white">Back to login</a>
    </form>
  </section>
</BaseLayout>
<script>
const form=document.getElementById('reset');const msg=document.getElementById('msg');const token=new URL(window.location.href).searchParams.get('token');
form?.addEventListener('submit', async(e)=>{e.preventDefault();const fd=new FormData(form);const res=await fetch('/api/auth/reset-password',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({token,password:fd.get('password'),confirmPassword:fd.get('confirmPassword')})});msg.textContent=res.ok?'Password reset successfully. You can now sign in.':'Unable to reset password.';});
</script>
