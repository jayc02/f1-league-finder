---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { privateNoStore, setAstroCache } from '@/lib/server/cache-control';
import { getSessionUser } from '@/lib/auth/session';
import { prisma } from '@/lib/db/prisma';
import CommunityEditorForm from '@/components/dashboard/CommunityEditorForm';

export const prerender = false;

// Private personalised route: dashboard/profile/admin HTML must never be public cached.
setAstroCache(Astro, privateNoStore);

const user = await getSessionUser(Astro as never);
if (!user) return Astro.redirect('/login');

const community = await prisma.organiserProfile.findUnique({
  where: { userId: user.id },
  select: {
    displayName: true,
    slug: true,
    shortDescription: true,
    description: true,
    brandingColor: true,
    logoUrl: true,
    bannerUrl: true,
    websiteUrl: true,
    discordUrl: true,
    redditUrl: true,
    gameFocus: true,
    platformFocus: true,
    region: true,
    tags: true,
    displayedMemberCount: true,
    memberCountSource: true,
    isPublic: true,
    featured: true,
    credibilityNotes: true,
  },
});

const isEditMode = Boolean(community);
const formTitle = isEditMode ? 'Manage Community' : 'Create Community';
---

<BaseLayout noindex={true} sessionUser={user} title="Community settings | RaceHub">
  <section class="section-shell">
    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Community control center</p>
    <h1 class="section-title mt-2">{formTitle}</h1>
    <p class="mt-3 max-w-3xl text-sm text-slate-300">{isEditMode ? 'Update your public RaceHub community hub without creating a duplicate organiser profile.' : 'Create your public RaceHub community hub, member-growth surface, and trust signals for incoming drivers.'}</p>
    <div class="mt-8">
      <CommunityEditorForm
        client:load
        mode={isEditMode ? 'edit' : 'create'}
        initialState={{
          displayName: community?.displayName ?? user.username,
          slug: community?.slug ?? user.username.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
          shortDescription: community?.shortDescription ?? '',
          description: community?.description ?? '',
          brandingColor: community?.brandingColor ?? '#E10600',
          logoUrl: community?.logoUrl ?? '',
          bannerUrl: community?.bannerUrl ?? '',
          websiteUrl: community?.websiteUrl ?? '',
          discordUrl: community?.discordUrl ?? '',
          redditUrl: community?.redditUrl ?? '',
          gameFocus: community?.gameFocus ?? '',
          platformFocus: community?.platformFocus ?? '',
          region: community?.region ?? user.region ?? 'GLOBAL',
          tags: (community?.tags ?? []).join(', '),
          displayedMemberCount: community?.displayedMemberCount ?? 0,
          memberCountSource: (community?.memberCountSource as 'manual' | 'discord-sync' | 'reddit-sync') ?? 'manual',
          isPublic: community?.isPublic ?? true,
          featured: community?.featured ?? false,
          credibilityNotes: community?.credibilityNotes ?? '',
        }}
      />
    </div>
  </section>
</BaseLayout>
