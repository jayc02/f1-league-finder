---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSessionUser } from '@/lib/auth/session';
import { prisma } from '@/lib/db/prisma';
import { shouldLogPerf, withPerf } from '@/lib/utils/perf';

export const prerender = false;

const routeStart = performance.now();
const user = await withPerf('dashboard.sessionLookup', () => getSessionUser(Astro as never));
if (!user) return Astro.redirect('/login');

const now = new Date();

const [upcomingRegistrations, upcomingEvents, organiserProfile] = await withPerf('dashboard.dataFetch', () =>
  Promise.all([
    prisma.raceRegistration.findMany({
      where: { userId: user.id, raceSlot: { scheduledAt: { gte: now } } },
      select: {
        raceSlot: { select: { id: true, title: true, scheduledAt: true, league: { select: { name: true } } } },
      },
      orderBy: { raceSlot: { scheduledAt: 'asc' } },
      take: 6,
    }),
    prisma.raceSlot.findMany({
      where: { scheduledAt: { gte: now }, status: { in: ['OPEN', 'FULL'] }, visibility: 'PUBLIC' },
      select: { id: true, title: true, scheduledAt: true, status: true, league: { select: { name: true } } },
      orderBy: { scheduledAt: 'asc' },
      take: 6,
    }),
    prisma.organiserProfile.findUnique({ where: { userId: user.id }, select: { displayName: true } }),
  ]),
);

if (shouldLogPerf()) console.info(`[perf] dashboard.routeTotal: ${(performance.now() - routeStart).toFixed(1)}ms`);
---
<BaseLayout noindex={true} title="Dashboard | RaceHub" sessionUser={user}>
  <section class="section-shell">
    <div class="panel rounded-3xl p-6 md:p-8">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Command center</p>
      <div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="section-title">Driver Hub · {user.username}</h1>
          <p class="mt-2 text-sm text-slate-300">Track momentum and stay race-ready across every championship slot.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a href="/profile/edit" class="rounded-full border border-white/20 bg-white/5 px-5 py-2 text-sm text-white transition hover:border-white/40 hover:bg-white/10">Edit profile</a>
          <a href="/dashboard/community" class="rounded-full bg-white px-5 py-2 text-sm font-semibold text-black">Create Community</a>
        </div>
      </div>
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-black/20 p-4"><p class="text-xs text-slate-400">Skill Rating</p><p class="mt-2 font-display text-3xl">{user.skillRating}</p></div>
        <div class="rounded-2xl border border-white/10 bg-black/20 p-4"><p class="text-xs text-slate-400">Honour</p><p class="mt-2 font-display text-3xl">{user.honourScore}</p></div>
      </div>
    </div>

    <!-- Accolade UI temporarily disabled for MVP clarity/performance. -->

    <div class="mt-8 grid gap-6 xl:grid-cols-2">
      <article class="panel rounded-3xl p-4 sm:p-6">
        <h2 class="font-display text-2xl">My Upcoming Races</h2>
        <div class="mt-4 space-y-3">
          {upcomingRegistrations.length ? upcomingRegistrations.map((registration) => (
            <a href={`/race-slots/${registration.raceSlot.id}`} class="block rounded-2xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-white/40 hover:bg-white/[0.07]">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400">{registration.raceSlot.league.name}</p>
              <h3 class="mt-1 font-semibold text-white">{registration.raceSlot.title}</h3>
              <p class="mt-2 text-xs text-slate-400">{new Date(registration.raceSlot.scheduledAt).toLocaleString()}</p>
            </a>
          )) : <p class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300">No upcoming registrations yet.</p>}
        </div>
      </article>

      <article class="panel rounded-3xl p-4 sm:p-6">
        <h2 class="font-display text-2xl">Available Races</h2>
        <div class="mt-4 space-y-2">
          {upcomingEvents.length ? upcomingEvents.map((slot) => (
            <a href={`/race-slots/${slot.id}`} class="block rounded-xl border border-white/10 bg-white/[0.03] px-3 py-3 transition hover:border-white/35">
              <p class="text-xs uppercase tracking-[0.16em] text-slate-500">{slot.league.name} · {slot.status}</p>
              <p class="mt-1 font-medium text-white">{slot.title}</p>
            </a>
          )) : <p class="rounded-xl border border-white/10 bg-white/[0.03] px-3 py-3 text-sm text-slate-300">No upcoming events available.</p>}
        </div>
      </article>
    </div>

    <article class="panel mt-6 rounded-3xl p-4 sm:p-6">
      <div class="flex items-center justify-between">
        <h2 class="font-display text-2xl">My Community</h2>
        <a href="/dashboard/community" class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.16em] text-slate-200 transition hover:border-white/40 hover:bg-white/10">Create Community</a>
      </div>
      <p class="mt-3 text-sm text-slate-300">{organiserProfile ? organiserProfile.displayName : 'You can create and manage your community at any time.'}</p>
    </article>
  </section>
</BaseLayout>
