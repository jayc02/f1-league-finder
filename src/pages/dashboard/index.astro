---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSessionUser } from '@/lib/auth/session';
import { fetchFromApi } from '@/lib/server-api';
import type { RaceSlotSummary } from '@/lib/api/types';

export const prerender = false;
const user = await getSessionUser(Astro as never);
if (!user) return Astro.redirect('/login');

const mySlots = await fetchFromApi<{ raceSlots: RaceSlotSummary[] }>(Astro, '/api/race-slots?status=OPEN&limit=12').catch(() => ({ raceSlots: [] }));
const disputes = await fetchFromApi<{ disputes: Array<{ id: string; reason: string; status: string; raceSlot: { title: string } }> }>(Astro, '/api/disputes').catch(() => ({ disputes: [] }));
---
<BaseLayout title="Dashboard | GRID//ONE">
  <section class="section-shell">
    <h1 class="section-title">Welcome, {user.username}</h1>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <div class="panel rounded-2xl p-5"><p class="text-xs text-slate-400">Skill Rating</p><p class="mt-2 font-display text-3xl">{user.skillRating}</p></div>
      <div class="panel rounded-2xl p-5"><p class="text-xs text-slate-400">Honour Score</p><p class="mt-2 font-display text-3xl">{user.honourScore}</p></div>
      <div class="panel rounded-2xl p-5"><p class="text-xs text-slate-400">Role</p><p class="mt-2 font-display text-3xl">{user.role}</p></div>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <div class="panel rounded-2xl p-5">
        <h2 class="font-display text-2xl">Available race slots</h2>
        <div class="mt-3 space-y-2">
          {mySlots.raceSlots.slice(0, 6).map((slot) => <a href={`/race-slots/${slot.id}`} class="block rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm">{slot.title} · {new Date(slot.scheduledAt).toLocaleString()}</a>)}
        </div>
      </div>
      <div class="panel rounded-2xl p-5">
        <h2 class="font-display text-2xl">Your disputes</h2>
        <div class="mt-3 space-y-2">
          {disputes.disputes.length ? disputes.disputes.map((dispute) => <div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm">{dispute.reason} · {dispute.status}</div>) : <p class="text-sm text-slate-300">No active disputes.</p>}
        </div>
      </div>
    </div>

    {(user.role === 'ORGANISER' || user.role === 'ADMIN') && (
      <div class="mt-8 panel rounded-2xl p-5">
        <h2 class="font-display text-2xl">Organiser controls</h2>
        <div class="mt-3 flex flex-wrap gap-3">
          <a href="/dashboard/race-slots/new" class="rounded-xl bg-white px-4 py-2 text-sm font-semibold text-black">Create race slot</a>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
