---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { privateNoStore, setAstroCache } from '@/lib/server/cache-control';
import { getSessionUser } from '@/lib/auth/session';
import { prisma } from '@/lib/db/prisma';
import RaceSlotEditorForm from '@/components/dashboard/RaceSlotEditorForm';

export const prerender = false;

// Private personalised route: dashboard/profile/admin HTML must never be public cached.
setAstroCache(Astro, privateNoStore);
const user = await getSessionUser(Astro as never);
if (!user) return Astro.redirect('/login');

const community = await prisma.organiserProfile.findFirst({
  where: {
    OR: [
      { userId: user.id },
      { members: { some: { userId: user.id, status: 'ACTIVE', role: { in: ['OWNER', 'ADMIN'] } } } },
    ],
  },
  select: { id: true },
});
if (!community && user.role !== 'ADMIN') return Astro.redirect('/dashboard/community');

const leagues = await prisma.league.findMany({
  where: user.role === 'ADMIN' ? {} : { OR: [{ ownerId: user.id }, { organiserProfileId: community?.id }] },
  select: { id: true, name: true },
});
---
<BaseLayout noindex={true} sessionUser={user} title="Create organiser event | RaceHub">
  <section class="section-shell">
    <h1 class="section-title">Create organiser event</h1>
    <p class="mt-2 text-slate-300">Build an event in draft, then publish it from your organiser dashboard when you are ready for public discovery.</p>
    <div class="mt-6">
      <RaceSlotEditorForm client:load leagues={leagues.map(({ id, name }) => ({ id, name }))} />
    </div>
  </section>
</BaseLayout>
