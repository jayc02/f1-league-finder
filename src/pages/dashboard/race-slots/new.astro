---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSessionUser } from '@/lib/auth/session';
import { fetchFromApi } from '@/lib/server-api';
import RaceSlotEditorForm from '@/components/dashboard/RaceSlotEditorForm';

export const prerender = false;
const user = await getSessionUser(Astro as never);
if (!user || !['ORGANISER', 'ADMIN'].includes(user.role)) return Astro.redirect('/login');

const leaguesResponse = await fetchFromApi<{ leagues: Array<{ id: string; name: string; ownerId: string }> }>(Astro, '/api/leagues').catch(() => ({ leagues: [] }));
const leagues = user.role === 'ADMIN' ? leaguesResponse.leagues : leaguesResponse.leagues.filter((league) => league.ownerId === user.id);
---
<BaseLayout title="Create race slot | GRID//ONE">
  <section class="section-shell">
    <h1 class="section-title">Create race slot</h1>
    <p class="mt-2 text-slate-300">Publish a premium lobby with full rules and registration controls.</p>
    <div class="mt-6">
      <RaceSlotEditorForm client:load leagues={leagues.map(({ id, name }) => ({ id, name }))} />
    </div>
  </section>
</BaseLayout>
