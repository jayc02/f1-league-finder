---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { privateNoStore, setAstroCache } from '@/lib/server/cache-control';
import { getSessionUser } from '@/lib/auth/session';
import { prisma } from '@/lib/db/prisma';
import RaceSlotEditorForm from '@/components/dashboard/RaceSlotEditorForm';

export const prerender = false;

// Private personalised route: dashboard/profile/admin HTML must never be public cached.
setAstroCache(Astro, privateNoStore);

const user = await getSessionUser(Astro as never);
if (!user) return Astro.redirect('/login');
const id = Astro.params.id;
if (!id) return Astro.redirect('/dashboard');

const slot = await prisma.raceSlot.findUnique({
  where: { id },
  select: { id: true, organiserId: true, organiserProfileId: true, leagueId: true, title: true, scheduledAt: true, registrationCutoffAt: true, maxPlayers: true, platform: true, region: true, track: true, visibility: true, status: true, crossplay: true, stakeTierMetadata: true, formatDetails: true, rulesSummary: true, eventNotes: true, cancellationReason: true, league: { select: { ownerId: true } }, organiserProfile: { select: { id: true, userId: true, members: { where: { userId: user.id, status: 'ACTIVE', role: { in: ['OWNER', 'ADMIN'] } }, select: { id: true } } } } },
});
if (!slot) return Astro.redirect('/dashboard');

const canEdit = user.role === 'ADMIN' || slot.organiserId === user.id || slot.league.ownerId === user.id || Boolean(slot.organiserProfile?.members.length);
if (!canEdit) return Astro.redirect('/dashboard');

const leagues = await prisma.league.findMany({
  where: user.role === 'ADMIN' ? {} : { OR: [{ ownerId: user.id }, { organiserProfileId: slot.organiserProfileId ?? undefined }] },
  select: { id: true, name: true },
});

const toLocalInput = (date: Date) => new Date(date.getTime() - date.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
---

<BaseLayout noindex={true} sessionUser={user} title="Edit event | RaceHub">
  <section class="section-shell">
    <h1 class="section-title">Edit organiser event</h1>
    <p class="mt-2 text-slate-300">Adjust schedule, visibility, entry controls, and event publishing status.</p>
    <div class="mt-6">
      <RaceSlotEditorForm
        client:load
        slotId={slot.id}
        leagues={leagues}
        defaults={{
          title: slot.title,
          track: slot.track ?? '',
          leagueId: slot.leagueId,
          scheduledAt: toLocalInput(slot.scheduledAt),
          registrationCutoffAt: toLocalInput(slot.registrationCutoffAt),
          maxPlayers: slot.maxPlayers,
          region: slot.region,
          platform: slot.platform ?? '',
          visibility: slot.visibility,
          status: slot.status,
          stakeTierMetadata: slot.stakeTierMetadata ?? '',
          formatDetails: slot.formatDetails,
          rulesSummary: slot.rulesSummary,
          eventNotes: slot.eventNotes ?? '',
          cancellationReason: slot.cancellationReason ?? '',
          crossplay: slot.crossplay,
        }}
      />
    </div>
  </section>
</BaseLayout>
