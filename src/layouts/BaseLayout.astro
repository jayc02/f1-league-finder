---
import '@/styles/global.css';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import PageMotion from '@/components/motion/PageMotion';
import CursorGlow from '@/components/ui/CursorGlow';
import { getSessionUser } from '@/lib/auth/session';
import { absoluteUrl, siteConfig } from '@/lib/config';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
  sessionUser?: import('@/lib/api/types').SessionUser | null;
  resolveSession?: boolean;
  lightweightApp?: boolean;
}

const hasSessionUserProp = Object.prototype.hasOwnProperty.call(Astro.props, 'sessionUser');

const {
  title = 'RaceHub | Competitive Sim Racing Platform',
  description = siteConfig.defaultDescription,
  canonicalPath = Astro.url.pathname,
  ogImage = '/og/racehub-default.svg',
  noindex = false,
  sessionUser: providedSessionUser = null,
  resolveSession = false,
  lightweightApp = false,
} = Astro.props;

const sessionUser = providedSessionUser ?? (resolveSession ? await getSessionUser(Astro as never) : null);
const authStateKnown = hasSessionUserProp || resolveSession;
const canonicalUrl = absoluteUrl(canonicalPath);
const ogImageUrl = /^https?:\/\//i.test(ogImage) ? ogImage : absoluteUrl(ogImage);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <style is:inline>
      html,
      body {
        margin: 0;
        min-height: 100%;
        background: #000;
        color: #fff;
      }

      body {
        overflow-x: hidden;
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        background: #000;
      }

      video[data-bg-video][data-video-failed='true'] {
        opacity: 0;
      }
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="application-name" content="RaceHub" />
    <meta name="apple-mobile-web-app-title" content="RaceHub" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter />
  </head>
  <body>
    <div id="app-shell">
      {!lightweightApp && <CursorGlow client:load />}
      {!lightweightApp && <PageMotion client:load />}
      <SiteHeader user={sessionUser} authStateKnown={authStateKnown} />
      <main class="pt-24">
        <slot />
      </main>
      <SiteFooter />
      <SpeedInsights />
    </div>
    <script>
      const isRaceHubBackgroundVideoDev = import.meta.env.DEV;
      const raceHubBackgroundVideoWindow = window as typeof window & {
        __raceHubBackgroundVideoListenersAttached?: boolean;
      };

      function initRaceHubBackgroundVideos() {
        document.querySelectorAll('video[data-bg-video]').forEach((video) => {
          if (!(video instanceof HTMLVideoElement)) return;

          video.muted = true;
          video.defaultMuted = true;
          video.playsInline = true;
          video.setAttribute('muted', '');
          video.setAttribute('playsinline', '');
          video.setAttribute('webkit-playsinline', '');
          video.setAttribute('autoplay', '');
          video.setAttribute('loop', '');

          const tryPlay = () => {
            if (isRaceHubBackgroundVideoDev) {
              console.debug('[RaceHub background video] attempting playback', {
                currentSrc: video.currentSrc,
                videoState: video.dataset.videoState,
              });
            }

            const promise = video.play();

            if (promise && typeof promise.catch === 'function') {
              promise
                .then(() => {
                  video.dataset.videoState = 'playing';
                  video.removeAttribute('data-video-failed');

                  if (isRaceHubBackgroundVideoDev) {
                    console.debug('[RaceHub background video] playback started', {
                      currentSrc: video.currentSrc,
                      videoState: video.dataset.videoState,
                    });
                  }
                })
                .catch((error) => {
                  video.dataset.videoState = 'failed';
                  video.setAttribute('data-video-failed', 'true');

                  if (isRaceHubBackgroundVideoDev) {
                    console.debug('[RaceHub background video] playback failed', {
                      currentSrc: video.currentSrc,
                      videoState: video.dataset.videoState,
                      error,
                    });
                  }
                });
            }
          };

          tryPlay();
        });
      }

      initRaceHubBackgroundVideos();

      if (!raceHubBackgroundVideoWindow.__raceHubBackgroundVideoListenersAttached) {
        document.addEventListener('astro:page-load', initRaceHubBackgroundVideos);
        document.addEventListener('astro:after-swap', initRaceHubBackgroundVideos);
        raceHubBackgroundVideoWindow.__raceHubBackgroundVideoListenersAttached = true;
      }
    </script>
  </body>
</html>
