---
import '@/styles/global.css';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import PageMotion from '@/components/motion/PageMotion';
import CursorGlow from '@/components/ui/CursorGlow';
import { getSessionUser } from '@/lib/auth/session';

interface Props { title?: string }
const { title = 'GRID//ONE | Competitive F1 League Platform' } = Astro.props;
const sessionUser = await getSessionUser(Astro as never);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Premium platform for organised F1 race slots, honour-driven rankings, and league operations." />
    <title>{title}</title>
  </head>
  <body>
    <CursorGlow client:load />
    <PageMotion client:load />
    <SiteHeader user={sessionUser} />
    <main class="pt-24">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
