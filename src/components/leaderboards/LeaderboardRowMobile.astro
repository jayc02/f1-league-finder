---
import HonourGradeBadge from '@/components/ui/HonourGradeBadge.astro';
interface Props { entry: any; current?: boolean; podium?: boolean; }
const { entry, current = false, podium = false } = Astro.props;
---
<article class:list={['flex w-full max-w-full items-center gap-3 rounded-2xl border px-3 py-3', current ? 'border-emerald-300/50 bg-emerald-400/10 shadow-[0_0_0_1px_rgba(110,231,183,0.12)]' : podium ? 'border-amber-200/25 bg-white/[0.07]' : 'border-white/10 bg-white/[0.04]']}>
  <p class="w-12 shrink-0 text-lg font-black text-white">#{entry.rank}</p>
  <img src={entry.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${entry.username}`} alt={`${entry.username} avatar`} class="h-10 w-10 shrink-0 rounded-xl border border-white/10 object-cover" loading="lazy" decoding="async" />
  <div class="min-w-0 flex-1">
    <p class="truncate text-sm font-semibold text-white">{entry.username}</p>
    <p class="text-xs text-slate-400 sm:hidden">{entry.skillRating} SR</p>
  </div>
  <div class="shrink-0 text-right">
    <p class="hidden text-sm font-semibold text-slate-100 sm:block">{entry.skillRating} SR</p>
    <HonourGradeBadge score={entry.honourScore} />
  </div>
</article>
