---
interface Props { entry: any; }
const { entry } = Astro.props;
---
<article class="leader-row"><p>#{entry.rank}</p><div class="min-w-0"><p class="truncate">{entry.username}</p><small>{entry.skillRating} SR · {entry.honourScore} Honour</small></div><p>{entry.weeklyPoints>=0?'+':''}{entry.weeklyPoints}</p></article>
