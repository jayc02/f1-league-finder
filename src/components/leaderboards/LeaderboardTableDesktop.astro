---
interface Props { entries: any[]; trendLabel: Record<string, string>; }
const { entries, trendLabel } = Astro.props;
---
<div class="mt-6 hidden rounded-3xl border border-white/15 bg-black/45 p-6 md:block">
  <div class="grid grid-cols-[70px_minmax(220px,1.45fr)_repeat(8,minmax(78px,1fr))] items-center px-4 pb-3 text-[11px] uppercase tracking-[0.2em] text-slate-500"><p>Rank</p><p>Driver</p><p>SR</p><p>Honour</p><p>Starts</p><p>Wins</p><p>Podiums</p><p>Clean</p><p>7D</p><p>Trend</p></div>
  <div class="space-y-2">{entries.map((entry) => <article class="rounded-2xl border border-white/10 bg-gradient-to-r from-white/[0.06] via-white/[0.03] to-white/[0.02] px-3 py-3 transition hover:border-white/35 hover:bg-white/[0.06]"><div class="grid gap-2 md:grid-cols-[70px_minmax(220px,1.45fr)_repeat(8,minmax(78px,1fr))] md:items-center"><p class="text-lg font-semibold text-white">#{entry.rank}</p><div class="flex min-w-0 items-center gap-3"><img src={entry.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${entry.username}`} alt={`${entry.username} avatar`} class="h-10 w-10 shrink-0 rounded-xl border border-white/10 object-cover" /><div class="min-w-0"><p class="truncate text-sm font-semibold text-white">{entry.username}</p><p class="truncate text-xs uppercase tracking-[0.18em] text-slate-500">{entry.region}</p></div></div><p class="text-sm text-slate-100">{entry.skillRating}</p><p class="text-sm text-slate-100">{entry.honourScore}</p><p class="text-sm text-slate-100">{entry.starts}</p><p class="text-sm text-slate-100">{entry.wins}</p><p class="text-sm text-slate-100">{entry.podiums}</p><p class="text-sm text-slate-100">{Math.round(entry.cleanRaceRatio * 100)}%</p><p class="text-sm text-slate-100">{entry.weeklyPoints}</p><p class="rh-badge rounded-full border border-white/10 bg-white/5 px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-slate-300">{trendLabel[entry.trend]}</p></div></article>)}</div>
</div>
