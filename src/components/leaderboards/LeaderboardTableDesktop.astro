---
interface Props { entries: any[]; }
const { entries } = Astro.props;
const tierFor = (r:number)=> r<=10?'tier-champion':r<=25?'tier-elite':r<=50?'tier-gold':r<=75?'tier-silver':'tier-bronze';
---
<div class="mt-6 hidden md:block">
  <div class="grid grid-cols-3 gap-3">{entries.slice(0,3).map((e)=><article class="card"><p>#{e.rank}</p><p class="text-xl">{e.username}</p><p>{e.skillRating} SR</p></article>)}</div>
  <div class="mt-4 space-y-2">{entries.map((entry)=><article class={`leader-row ${tierFor(entry.rank)}`}><div>#{entry.rank}</div><div class="flex items-center gap-2"><img src={entry.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${entry.username}`} class="h-9 w-9 rounded"/><div><p>{entry.username} <span class="tag">#RH{1000+entry.rank}</span></p><small>{entry.wins}W-{Math.max(0,entry.starts-entry.wins)}L</small></div></div><div>{entry.skillRating}</div><div>{entry.honourScore}</div><div>{Math.round(entry.cleanRaceRatio*100)}%</div><div>{entry.weeklyPoints>=0?'+':''}{entry.weeklyPoints}</div></article>)}</div>
</div>
