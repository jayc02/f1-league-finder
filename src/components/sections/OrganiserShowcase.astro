<section id="organisers" class="section-shell" data-reveal>
  <div class="panel rounded-3xl p-6 md:p-8">
    <p class="text-xs uppercase tracking-[0.25em] text-slate-400">For organisers and communities</p>
    <div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <h2 class="section-title">Build a branded community hub and fill every grid.</h2>
      <a href="/communities" class="rounded-full border border-white/20 bg-white/5 px-5 py-2 text-xs uppercase tracking-[0.18em] transition hover:border-white/40 hover:bg-white/10">Explore communities</a>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {[
        ['Community branding', 'Custom banner, logo, social links, and credibility markers.'],
        ['Live promotion', 'Public community profile featuring upcoming race inventory.'],
        ['Event publishing', 'Publish, draft, unlist, or cancel race slots with one workflow.'],
        ['Audience ops', 'Track member count signals and convert discovery traffic.']
      ].map(([title, text]) => (
        <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition hover:-translate-y-2 hover:border-white/25">
          <h3 class="font-display text-2xl text-white">{title}</h3>
          <p class="mt-3 text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
