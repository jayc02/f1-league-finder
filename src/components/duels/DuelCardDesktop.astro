---
interface Props { duel: any; statusTone: Record<string, string>; }
const { duel, statusTone } = Astro.props;
---
<a href={`/duels/${duel.id}`} class="group relative hidden overflow-hidden rounded-3xl border border-white/20 bg-gradient-to-br from-white/[0.09] via-black/60 to-black/85 p-5 shadow-[0_24px_70px_rgba(0,0,0,0.58)] transition hover:-translate-y-1 hover:border-white/45 md:block">
  <div class="flex items-start justify-between gap-4"><div class="min-w-0"><p class="truncate text-xs uppercase tracking-[0.2em] text-slate-400">{duel.game} · {duel.track}</p><h2 class="mt-2 truncate font-display text-2xl text-white">{duel.createdBy.username} <span class="text-slate-500">vs</span> {duel.opponent?.username ?? 'Open opponent'}</h2></div><span class:list={['rh-badge rounded-full border px-3 py-1 text-[10px] uppercase tracking-[0.18em]', statusTone[duel.status] ?? 'border-white/20 bg-white/10 text-white']}>{duel.status.replaceAll('_', ' ')}</span></div>
  <div class="mt-5 grid gap-3 sm:grid-cols-3"><p class="rounded-2xl border border-white/10 bg-black/25 p-3 text-sm text-slate-300"><span class="block text-[11px] uppercase tracking-[0.16em] text-slate-500">Schedule</span>{duel.scheduledAt ? new Date(duel.scheduledAt).toLocaleString() : 'Open challenge'}</p><p class="rounded-2xl border border-white/10 bg-black/25 p-3 text-sm text-slate-300"><span class="block text-[11px] uppercase tracking-[0.16em] text-slate-500">Format</span>{duel.raceLength} · {duel.weather}</p><p class="rounded-2xl border border-white/10 bg-black/25 p-3 text-sm text-slate-300"><span class="block text-[11px] uppercase tracking-[0.16em] text-slate-500">Mode</span>{duel.ranked ? 'Ranked' : 'Unranked'} · {duel.crossplay ? 'Crossplay' : duel.platform ?? 'Platform lock'}</p></div>
  <div class="mt-4 flex items-center justify-between gap-3 text-xs uppercase tracking-[0.16em] text-slate-400"><span class="truncate">{duel.community?.displayName ?? 'Public arena'}</span><span class="rh-badge rounded-full bg-white px-3 py-2 font-semibold text-black">{duel.status === 'OPEN' ? 'Accept' : 'View'}</span></div>
</a>
