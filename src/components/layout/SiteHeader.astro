---
import type { SessionUser } from '@/lib/api/types';
import AuthNav from './AuthNav';

interface Props {
  user: SessionUser | null;
  authStateKnown?: boolean;
}

const { user, authStateKnown = false } = Astro.props;
const appNav = [
  { label: '1v1 Duels', href: '/duels' },
  { label: 'Race Slots', href: '/race-slots' },
  { label: 'Communities', href: '/communities' },
  { label: 'Rankings', href: '/leaderboards' },
  { label: 'Leagues', href: '/leagues' },
  ...(user ? [{ label: 'Dashboard', href: '/dashboard' }, ...(user.role === 'ADMIN' ? [{ label: 'Admin', href: '/admin' }] : []), { label: 'Profile', href: '/profile' }] : []),
];
---

<header class="fixed left-0 top-0 z-[90] w-full border-b border-white/[0.05] bg-black/35 backdrop-blur-xl" data-header>
  <div class="mx-auto flex w-[min(1280px,94vw)] items-center justify-between gap-3 py-3 md:py-4">
    <a href="/" data-astro-prefetch="hover" data-pressable class="font-display text-base tracking-[0.2em] text-white sm:text-lg sm:tracking-[0.24em]">RaceHub</a>

    <nav class="hidden gap-7 text-sm text-slate-200/90 lg:flex">
      {appNav.map((item) => <a href={item.href} data-astro-prefetch={['/duels', '/race-slots', '/communities', '/leaderboards', '/leagues'].includes(item.href) ? 'viewport' : undefined} data-pressable class="transition hover:text-white">{item.label}</a>)}
    </nav>

    <div class="hidden lg:block">
      <AuthNav client:idle user={user} authStateKnown={authStateKnown} />
    </div>

    <button
      type="button"
      class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-xl border border-white/20 bg-white/[0.06] text-white lg:hidden"
      aria-label="Open navigation"
      aria-expanded="false"
      data-mobile-menu-toggle
    >
      <span class="sr-only">Open navigation</span>
      ☰
    </button>
  </div>

  <div class="fixed inset-0 z-[80] hidden bg-black/55 backdrop-blur-sm lg:hidden" data-mobile-menu-backdrop></div>

  <div class="pointer-events-auto fixed inset-x-3 top-[4.5rem] z-[100] hidden rounded-3xl border border-white/15 bg-black/95 px-3 py-4 shadow-[0_28px_80px_rgba(0,0,0,.75)] lg:hidden" data-mobile-menu>
    <nav class="grid gap-2">
      {appNav.map((item) => (
        <a href={item.href} data-astro-prefetch={['/duels', '/race-slots', '/communities', '/leaderboards', '/leagues'].includes(item.href) ? 'hover' : undefined} data-pressable class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-slate-100 transition hover:border-white/30 hover:bg-white/10">{item.label}</a>
      ))}
    </nav>

    <div class="mt-3 grid gap-2">
      {!user ? (
        <>
          <a href="/login" class="rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-center text-sm text-slate-100">Sign in</a>
          <a href="/register" class="rounded-xl bg-white px-4 py-3 text-center text-sm font-semibold text-slate-900">Create account</a>
        </>
      ) : (
        <>
          <a href="/profile" class="flex items-center gap-3 rounded-xl border border-white/20 bg-white/[0.04] px-4 py-3 text-sm text-slate-100">
            <img src={user.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${user.username}`} alt={`${user.username} avatar`} class="h-8 w-8 rounded-lg border border-white/10 object-cover" />
            <span>{user.username}</span>
          </a>
          <button type="button" data-mobile-logout class="rounded-xl border border-rose-300/30 bg-rose-500/15 px-4 py-3 text-sm text-rose-100">Logout</button>
        </>
      )}
    </div>
  </div>
</header>

<script>
  function initRaceHubMobileMenu() {
    const toggle = document.querySelector('[data-mobile-menu-toggle]');
    const menu = document.querySelector('[data-mobile-menu]');
    const backdrop = document.querySelector('[data-mobile-menu-backdrop]');
    const logoutButton = document.querySelector('[data-mobile-logout]');

    if (!toggle || !menu) return;

    function openMenu() {
      menu.classList.remove('hidden');
      backdrop?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.documentElement.classList.add('mobile-menu-open');
    }

    function closeMenu() {
      menu.classList.add('hidden');
      backdrop?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.documentElement.classList.remove('mobile-menu-open');
    }

    if (toggle.dataset.menuBound !== 'true') {
      toggle.dataset.menuBound = 'true';
      toggle.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const isHidden = menu.classList.contains('hidden');
        if (isHidden) openMenu();
        else closeMenu();
      });
    }

    menu.querySelectorAll('a').forEach((link) => {
      if (link.dataset.menuCloseBound === 'true') return;
      link.dataset.menuCloseBound = 'true';
      link.addEventListener('click', closeMenu);
    });

    if (backdrop && backdrop.dataset.menuBackdropBound !== 'true') {
      backdrop.dataset.menuBackdropBound = 'true';
      backdrop.addEventListener('click', closeMenu);
    }

    if (logoutButton && logoutButton.dataset.logoutBound !== 'true') {
      logoutButton.dataset.logoutBound = 'true';
      logoutButton.addEventListener('click', async (event) => {
        event.preventDefault();
        closeMenu();
        await fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' });
        window.location.assign('/');
      });
    }

    if (document.documentElement.dataset.mobileMenuLifecycleBound !== 'true') {
      document.documentElement.dataset.mobileMenuLifecycleBound = 'true';
      document.addEventListener('astro:before-swap', closeMenu);
    }
  }

  initRaceHubMobileMenu();
  document.addEventListener('astro:page-load', initRaceHubMobileMenu);
  document.addEventListener('astro:after-swap', initRaceHubMobileMenu);
</script>
