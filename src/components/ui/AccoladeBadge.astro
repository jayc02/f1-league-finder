---
import type { PlayerAccolade } from '@/server/services/accolade.service';

interface Props {
  accolade: PlayerAccolade;
  compact?: boolean;
}

const { accolade, compact = false } = Astro.props;

const tierStyles: Record<PlayerAccolade['tier'], { ring: string; bg: string; text: string; glow: string }> = {
  legend: {
    ring: 'border-amber-200/60',
    bg: 'from-amber-300/35 via-amber-500/20 to-amber-900/35',
    text: 'text-amber-100',
    glow: 'shadow-[0_0_28px_rgba(251,191,36,0.3)]',
  },
  elite: {
    ring: 'border-indigo-200/55',
    bg: 'from-indigo-300/30 via-violet-500/20 to-indigo-900/35',
    text: 'text-indigo-100',
    glow: 'shadow-[0_0_26px_rgba(129,140,248,0.28)]',
  },
  pro: {
    ring: 'border-emerald-200/55',
    bg: 'from-emerald-300/28 via-emerald-500/18 to-emerald-900/35',
    text: 'text-emerald-100',
    glow: 'shadow-[0_0_22px_rgba(16,185,129,0.23)]',
  },
  core: {
    ring: 'border-slate-200/35',
    bg: 'from-slate-300/20 via-slate-500/14 to-slate-900/32',
    text: 'text-slate-100',
    glow: 'shadow-[0_0_18px_rgba(148,163,184,0.18)]',
  },
};

const categoryMark: Record<PlayerAccolade['category'], string> = {
  rank: 'M12 2l2.6 5.2 5.7.8-4.1 4 1 5.8L12 15.8 6.8 18l1-5.8-4.1-4 5.7-.8L12 2z',
  performance: 'M12 3l6 4v5c0 4.7-3 8-6 9-3-1-6-4.3-6-9V7l6-4zm0 4.4-2.2 1.4v2.9c0 2.9 1.2 5 2.2 6 1-1 2.2-3.1 2.2-6V8.8L12 7.4z',
  clean: 'M5 12.5l4.3 4.3L19 7.2l-1.8-1.8-8 8-2.5-2.5L5 12.5z',
  activity: 'M4 13h3.2l1.7-5 2.4 8 2.2-5H20',
  status: 'M12 3a8.9 8.9 0 00-8.9 8.9A8.9 8.9 0 0012 20.8a8.9 8.9 0 008.9-8.9A8.9 8.9 0 0012 3zm0 3.2l1.5 3.1 3.4.5-2.5 2.4.6 3.4-3-1.6-3 1.6.6-3.4-2.5-2.4 3.4-.5L12 6.2z',
};

const style = tierStyles[accolade.tier];
---

<span class:list={[
  'inline-flex items-center gap-2 rounded-xl border bg-black/35 pr-3 pl-2 py-1.5 align-middle backdrop-blur-sm',
  style.ring,
  style.glow,
  compact ? 'max-w-[210px]' : 'max-w-[260px] py-2.5 pr-4',
]} title={accolade.description}>
  <span class:list={[
    'relative flex h-7 w-7 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-white/25 bg-gradient-to-br',
    style.bg,
    compact ? 'h-6 w-6 rounded-md' : 'h-8 w-8',
  ]}>
    <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 text-white/95" aria-hidden="true">
      <path d={categoryMark[accolade.category]} fill="currentColor"></path>
    </svg>
    <span class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,.36),transparent_56%)]"></span>
  </span>
  <span class="min-w-0">
    <span class:list={['block truncate text-[10px] uppercase tracking-[0.16em] text-slate-400', compact ? '' : 'mb-0.5']}>{accolade.category}</span>
    <span class:list={['block truncate text-xs font-semibold uppercase tracking-[0.09em]', style.text, compact ? '' : 'text-sm']}>{accolade.title}</span>
  </span>
</span>
