---
interface Props {
  href: string;
  class?: string;
  fullWidthOnMobile?: boolean;
  label?: string;
}

const { href, class: className = '', fullWidthOnMobile = true, label = 'Join this community on Discord' } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class:list={[
    'rh-action-btn rh-discord-btn',
    fullWidthOnMobile ? 'w-full sm:w-auto' : 'w-auto',
    className,
  ]}
>
  <svg viewBox="0 0 127.14 96.36" fill="currentColor" aria-hidden="true" class="h-5 w-5 shrink-0">
    <path d="M107.7 8.07A105.15 105.15 0 0081.47 0a72.06 72.06 0 00-3.36 6.83A97.68 97.68 0 0048 6.83 72.37 72.37 0 0044.64 0 105.89 105.89 0 0018.39 8.09C1.03 34.16-3.66 59.43-1.32 84.36a105.73 105.73 0 0032.17 16.18 77.7 77.7 0 006.89-11.25 68.42 68.42 0 01-10.84-5.18c.91-.66 1.8-1.34 2.66-2.06a75.57 75.57 0 0067.58 0c.87.72 1.76 1.4 2.67 2.06a68.68 68.68 0 01-10.86 5.19 77 77 0 006.89 11.24 105.25 105.25 0 0032.19-16.18c2.74-28.88-4.68-53.92-20.33-76.29zM42.45 65.69c-6.27 0-11.41-5.73-11.41-12.75S36.07 40.2 42.45 40.2c6.39 0 11.52 5.78 11.41 12.74 0 7.02-5.03 12.75-11.41 12.75zm42.24 0c-6.27 0-11.41-5.73-11.41-12.75S78.32 40.2 84.69 40.2c6.39 0 11.52 5.78 11.41 12.74 0 7.02-5.02 12.75-11.41 12.75z"/>
  </svg>
  <span class="whitespace-nowrap">Join Discord</span>
</a>
